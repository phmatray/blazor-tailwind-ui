@namespace DaisyBlazor

@* MudDialog replacement. Renders title / body / actions sections inside the modal-box that the
   DialogProvider establishes. Reads the cascaded IMudDialogInstance for the title fallback. *@

@if (TitleContent is not null)
{
    <div class="@_titleCls">
        @TitleContent
    </div>
}
else if (!string.IsNullOrEmpty(_title))
{
    <h3 class="@_titleCls">@_title</h3>
}

<div class="@_bodyCls">
    @DialogContent
    @ChildContent
</div>

@if (_actions is not null)
{
    <div class="modal-action mt-6">
        @_actions
    </div>
}

@code {
    [CascadingParameter] private IMudDialogInstance? DialogInstance { get; set; }

    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? DialogContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Footer actions. <c>DialogActions</c> matches the MudBlazor child-content name;
    /// <c>Actions</c> is supported as an alias.</summary>
    [Parameter] public RenderFragment? DialogActions { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    [Parameter] public string? Title { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string? _title => !string.IsNullOrEmpty(Title) ? Title : DialogInstance?.Title;

    private RenderFragment? _actions => DialogActions ?? Actions;

    private string _titleCls => CssClass.Merge("font-heading text-lg font-semibold", Class);

    private string _bodyCls => "py-2 text-base-content";
}
