@namespace DaisyBlazor
@using System.Globalization

@* MudDatePicker replacement. Native input type=date bound to a DateTime?. Exposes both Date and
   Value (alias) so existing @bind-Date / @bind-Value usage keeps working. *@

<div class="@_fieldsetCls" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="label">
            <span class="label-text">@Label</span>
        </label>
    }
    <input type="date"
           class="@_inputCls"
           value="@_isoValue"
           min="@_minIso"
           max="@_maxIso"
           placeholder="@Placeholder"
           disabled="@Disabled"
           readonly="@ReadOnly"
           @onchange="OnChange"
           @attributes="UserAttributes" />
</div>

@code {
    [Parameter] public DateTime? Date { get; set; }
    [Parameter] public EventCallback<DateTime?> DateChanged { get; set; }
    [Parameter] public DateTime? Value { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Outlined;
    [Parameter] public Margin Margin { get; set; } = Margin.Normal;
    [Parameter] public bool Dense { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Editable { get; set; } = true;
    [Parameter] public bool Clearable { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public DateTime? MinDate { get; set; }
    [Parameter] public DateTime? MaxDate { get; set; }
    [Parameter] public string? DateFormat { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public string? AdornmentIcon { get; set; }
    [Parameter] public object? For { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private bool _isDense => Dense || Margin == Margin.Dense;

    private DateTime? _current => Date ?? Value;

    private string? _isoValue => _current?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? _minIso => MinDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    private string? _maxIso => MaxDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    private string _fieldsetCls => CssClass.Merge(
        "fieldset",
        FullWidth ? "w-full" : null,
        Class);

    private string _inputCls => CssClass.Merge(
        "input",
        Variant == Variant.Outlined ? "input-bordered" : null,
        Variant == Variant.Filled ? "input-bordered bg-base-200" : null,
        _isDense ? "input-sm" : null,
        FullWidth ? "w-full" : null);

    private async Task OnChange(ChangeEventArgs args)
    {
        string? raw = args.Value?.ToString();
        DateTime? parsed = null;

        if (!string.IsNullOrWhiteSpace(raw)
            && DateTime.TryParse(raw, CultureInfo.InvariantCulture, DateTimeStyles.None, out DateTime d))
        {
            parsed = d;
        }

        Date = parsed;
        Value = parsed;
        await DateChanged.InvokeAsync(parsed);
        await ValueChanged.InvokeAsync(parsed);
    }
}
