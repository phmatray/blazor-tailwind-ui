@namespace DaisyBlazor

@* MudIcon replacement. Renders a Material Symbols glyph from an Icons.* ligature.
   Use Name (or the alias Icon via the IconName helper) e.g. <Icon Name="@Icons.Material.Filled.Menu" />.
   For a non-Material icon set, cascade an IconOptions to swap the font class, or pass inline
   SVG as child content (which suppresses the ligature font entirely). *@

@if (ChildContent is not null)
{
    <span class="@CssClass.Merge("inline-flex select-none align-middle leading-none", _colorClass, Class)"
          style="@Style"
          aria-hidden="true"
          @attributes="UserAttributes">@ChildContent</span>
}
else
{
    <span class="@CssClass.Merge(_fontClass, _layoutClass, _sizeClass, _colorClass, Class)"
          style="@($"{_style}{Style}")"
          aria-hidden="true"
          @attributes="UserAttributes">@Name</span>
}

@code {
    /// <summary>Material Symbols ligature (from the <c>Icons</c> class). Ignored when <see cref="ChildContent"/> is set.</summary>
    [Parameter] public string? Name { get; set; }

    /// <summary>
    /// Optional inline content (typically an SVG) rendered instead of a font ligature. When set,
    /// the icon-font class is omitted, freeing non-Material apps from the Material Symbols dependency.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public Color Color { get; set; } = Color.Inherit;

    /// <summary>Render the outlined (unfilled) variant.</summary>
    [Parameter] public bool Outlined { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    /// <summary>Optional cascaded options; swaps the icon-font class when supplied.</summary>
    [CascadingParameter] private IconOptions? Options { get; set; }

    private string _fontClass => Options?.FontClass ?? IconOptions.DefaultFontClass;

    private const string _layoutClass = "select-none align-middle leading-none";

    private string _sizeClass => Size switch
    {
        Size.Small => "text-[1.125rem]",
        Size.Large => "text-[2.25rem]",
        _ => "text-[1.5rem]"
    };

    private string? _colorClass => CssClass.TextColor(Color);

    private string _style => Outlined
        ? "font-variation-settings:'FILL' 0,'wght' 400;"
        : "font-variation-settings:'FILL' 1,'wght' 400;";
}
