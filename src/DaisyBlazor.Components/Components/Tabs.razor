@namespace DaisyBlazor

@* Tabs container. daisyUI .tabs with variant modifiers tabs-box | tabs-border | tabs-lift
   and sizes tabs-xs | tabs-sm | tabs-md | tabs-lg | tabs-xl.
   Cascades itself so each <Tab> can register and query the active index. *@

<CascadingValue Value="this" IsFixed="false">
    @* Render the Tab children so they register with this container (each Tab renders no markup itself). *@
    @ChildContent

    <div class="@_cls" style="@Style" @attributes="UserAttributes">
        @* Tab button row *@
        <div role="tablist" class="tabs @_variantClass @_sizeClass">
            @foreach (Tab tab in _tabs)
            {
                <button role="tab"
                        type="button"
                        class="@TabButtonClass(tab)"
                        disabled="@tab.Disabled"
                        @onclick="() => SetActive(tab)">
                    @tab.Title
                </button>
            }
        </div>

        @* Active tab panel *@
        @if (_activeTab is not null)
        {
            <div role="tabpanel" class="tab-content">
                @_activeTab.ChildContent
            </div>
        }
    </div>
</CascadingValue>

@code {
    private readonly List<Tab> _tabs = new();
    private Tab? _activeTab;

    /// <summary>The tab definitions (one or more <see cref="Tab"/> components).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Zero-based index of the currently active tab.</summary>
    [Parameter] public int ActiveIndex { get; set; }

    /// <summary>Raised when the active index changes.</summary>
    [Parameter] public EventCallback<int> ActiveIndexChanged { get; set; }

    /// <summary>Visual style of the tab strip (Box, Border, or Lift).</summary>
    [Parameter] public TabsVariant Variant { get; set; } = TabsVariant.Box;

    /// <summary>Size of the tab buttons.</summary>
    [Parameter] public Size Size { get; set; } = Size.Medium;

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string _variantClass => Variant switch
    {
        TabsVariant.Border => "tabs-border",
        TabsVariant.Lift => "tabs-lift",
        _ => "tabs-box"
    };

    private string _sizeClass => Size switch
    {
        Size.Small => "tabs-sm",
        Size.Large => "tabs-lg",
        _ => string.Empty
    };

    private string _cls => CssClass.Merge("w-full", Class);

    private string TabButtonClass(Tab tab)
    {
        bool isActive = _activeTab == tab;
        return CssClass.Merge("tab", isActive ? "tab-active" : null);
    }

    /// <summary>Called by each <see cref="Tab"/> during OnInitialized to register itself.</summary>
    public void RegisterTab(Tab tab)
    {
        if (!_tabs.Contains(tab))
        {
            _tabs.Add(tab);
        }

        // Keep the active tab in sync with ActiveIndex (clamped), defaulting to the first tab.
        _activeTab = ActiveIndex >= 0 && ActiveIndex < _tabs.Count
            ? _tabs[ActiveIndex]
            : _tabs.Count > 0 ? _tabs[0] : null;

        StateHasChanged();
    }

    /// <summary>Called by each <see cref="Tab"/> during Dispose to unregister itself.</summary>
    public void UnregisterTab(Tab tab)
    {
        _tabs.Remove(tab);
        if (_activeTab == tab)
        {
            _activeTab = _tabs.Count > 0 ? _tabs[0] : null;
        }

        StateHasChanged();
    }

    private async Task SetActive(Tab tab)
    {
        _activeTab = tab;
        int index = _tabs.IndexOf(tab);
        ActiveIndex = index;
        await ActiveIndexChanged.InvokeAsync(index);
    }

    /// <summary>Activates the tab at the given zero-based index programmatically.</summary>
    public async Task SetActiveIndexAsync(int index)
    {
        if (index >= 0 && index < _tabs.Count)
        {
            await SetActive(_tabs[index]);
        }
    }

    protected override void OnParametersSet()
    {
        // Sync ActiveIndex if it changed from the parent without a click.
        if (ActiveIndex >= 0 && ActiveIndex < _tabs.Count)
        {
            Tab target = _tabs[ActiveIndex];
            if (_activeTab != target)
            {
                _activeTab = target;
            }
        }
    }
}
