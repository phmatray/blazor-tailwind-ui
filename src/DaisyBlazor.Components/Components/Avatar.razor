@namespace DaisyBlazor

@* MudAvatar replacement. daisyUI .avatar; shows an image when Image is set,
   otherwise renders initials / icon via ChildContent inside a colored circle. *@

<div class="@_wrapperCls" style="@Style" @attributes="UserAttributes">
    <div class="@_innerCls">
        @if (!string.IsNullOrEmpty(Image))
        {
            <img src="@Image" alt="@Alt" />
        }
        else
        {
            <span class="text-sm font-medium leading-none">@ChildContent</span>
        }
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Image source; when set the avatar renders an &lt;img&gt;.</summary>
    [Parameter] public string? Image { get; set; }

    /// <summary>Alt text for the image.</summary>
    [Parameter] public string? Alt { get; set; }

    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private bool _hasImage => !string.IsNullOrEmpty(Image);

    private string _sizeClass => Size switch
    {
        Size.Small => "w-8",
        Size.Large => "w-16",
        _ => "w-12"
    };

    private string _colorClass => _hasImage
        ? string.Empty
        : Color switch
        {
            Color.Primary => "bg-primary text-primary-content",
            Color.Secondary => "bg-secondary text-secondary-content",
            Color.Tertiary => "bg-accent text-accent-content",
            Color.Info => "bg-info text-info-content",
            Color.Success => "bg-success text-success-content",
            Color.Warning => "bg-warning text-warning-content",
            Color.Error => "bg-error text-error-content",
            Color.Dark => "bg-neutral text-neutral-content",
            _ => "bg-base-300 text-base-content"
        };

    private string _wrapperCls => CssClass.Merge(
        "avatar",
        _hasImage ? null : "avatar-placeholder",
        Class);

    private string _innerCls => CssClass.Merge(
        _sizeClass,
        _colorClass,
        "rounded-full",
        "flex items-center justify-center overflow-hidden");
}
