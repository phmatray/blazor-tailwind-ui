@namespace DaisyBlazor

@* MudColorPicker replacement. Native input type=color bound to a hex string. Exposes Text and
   Value aliases so existing @bind-Text / @bind-Value usage keeps working. *@

<div class="@_fieldsetCls" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="label">
            <span class="label-text">@Label</span>
        </label>
    }
    <label class="@_wrapperCls">
        <input type="color"
               class="w-8 h-8 p-0 border-0 bg-transparent cursor-pointer"
               value="@_hex"
               disabled="@Disabled"
               @onchange="OnChange"
               @attributes="UserAttributes" />
        <span class="grow font-mono text-sm">@_current</span>
    </label>
</div>

@code {
    [Parameter] public string? Text { get; set; }
    [Parameter] public EventCallback<string?> TextChanged { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public PickerVariant PickerVariant { get; set; } = PickerVariant.Inline;
    [Parameter] public ColorPickerView ColorPickerView { get; set; } = ColorPickerView.Spectrum;

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string? _current => Text ?? Value;

    private string _hex => string.IsNullOrWhiteSpace(_current) ? "#000000" : _current!;

    private string _fieldsetCls => CssClass.Merge(
        "fieldset",
        FullWidth ? "w-full" : null,
        Class);

    private string _wrapperCls => CssClass.Merge(
        "input input-bordered flex items-center gap-2",
        FullWidth ? "w-full" : null);

    private async Task OnChange(ChangeEventArgs args)
    {
        string? hex = args.Value?.ToString();
        Text = hex;
        Value = hex;
        await TextChanged.InvokeAsync(hex);
        await ValueChanged.InvokeAsync(hex);
    }
}
