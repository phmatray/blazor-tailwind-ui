@namespace DaisyBlazor
@typeparam T

@* MudChip<T> replacement. daisyUI .badge with color/size/variant, optional leading icon,
   click handling and an optional close button. *@

@if (OnClick.HasDelegate)
{
    <button type="button" class="@_cls" style="@Style" @onclick="OnClickHandler" @attributes="UserAttributes">
        @ChipInner
    </button>
}
else
{
    <span class="@_cls" style="@Style" @attributes="UserAttributes">
        @ChipInner
    </span>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Backing value for selection scenarios.</summary>
    [Parameter] public T? Value { get; set; }

    /// <summary>Text shown when no ChildContent is supplied.</summary>
    [Parameter] public string? Text { get; set; }

    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;

    /// <summary>Leading icon ligature.</summary>
    [Parameter] public string? Icon { get; set; }

    /// <summary>Close icon ligature for the optional close button.</summary>
    [Parameter] public string? CloseIcon { get; set; }

    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>Raised when the close button is clicked; rendering it requires a delegate.</summary>
    [Parameter] public EventCallback<Chip<T>> OnClose { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string _variantClass => Variant switch
    {
        Variant.Outlined => "badge-outline",
        Variant.Text => "badge-soft",
        _ => string.Empty
    };

    private string _cls => CssClass.Merge(
        "badge",
        CssClass.BadgeColor(Color),
        CssClass.BadgeSize(Size),
        _variantClass,
        "gap-1",
        Class);

    private RenderFragment ChipInner => @<text>
        @if (!string.IsNullOrEmpty(Icon))
        {
            <Icon Name="@Icon" Size="Size.Small" />
        }
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @Text
        }
        @if (OnClose.HasDelegate)
        {
            <button type="button" class="btn btn-ghost btn-xs btn-circle -mr-1" @onclick="OnCloseHandler" @onclick:stopPropagation="true">
                <Icon Name="@(string.IsNullOrEmpty(CloseIcon) ? Icons.Material.Filled.Close : CloseIcon)" Size="Size.Small" />
            </button>
        }
    </text>;

    private async Task OnClickHandler(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(args);
        }
    }

    private async Task OnCloseHandler()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync(this);
        }
    }
}
