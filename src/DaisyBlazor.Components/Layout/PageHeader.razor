@namespace DaisyBlazor.Layout

@* PageHeader: title + optional subtitle on the left, optional action slot on the right. *@

<Stack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
       Class="@Class" Style="@Style" @attributes="UserAttributes">
    <Stack Spacing="0">
        <Typography Typo="Typo.h4">@Title</Typography>
        @if (Subtitle is not null)
        {
            <Typography Typo="Typo.body2" Color="Color.Secondary">@Subtitle</Typography>
        }
    </Stack>
    @if (Actions is not null)
    {
        <Stack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            @Actions
        </Stack>
    }
</Stack>
