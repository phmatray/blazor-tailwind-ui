@namespace DaisyBlazor.Charts

@* Dependency-free line chart. Renders one or more ChartSeries as inline SVG polylines (optionally
   smoothed and/or area-filled) over a gridded, labelled axis area. Colors follow the active daisyUI
   theme via the cycling ChartPalette unless a series sets its own Color. *@

<div class="@_cls" style="@_style" @attributes="UserAttributes">
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="text-sm font-medium mb-2 text-base-content/80">@Title</div>
    }

    <svg viewBox="0 0 @_w.ToString(_ci) @_h.ToString(_ci)"
         preserveAspectRatio="none"
         role="img"
         class="w-full"
         style="@($"height:{Height};")"
         aria-label="@(_ariaLabel)">
        <title>@_ariaLabel</title>

        @* Horizontal gridlines + value labels *@
        @if (ShowGrid)
        {
            @foreach ((double y, string label) in _yGrid)
            {
                <line x1="@_padLeft.ToString(_ci)" y1="@y.ToString(_ci)"
                      x2="@(( _w - _padRight)).ToString(_ci)" y2="@y.ToString(_ci)"
                      stroke="var(--color-base-content)" stroke-opacity="0.12" stroke-width="1" />
                <SvgText X="@(_padLeft - 4)" Y="@(y + 4)" Anchor="end" FillOpacity="0.6" Text="@label" />
            }
        }

        @* X axis labels *@
        @if (Labels is { Count: > 0 })
        {
            @for (int i = 0; i < Labels.Count; i++)
            {
                <SvgText X="@_xAt(i)" Y="@(_h - _padBottom + 16)" Anchor="middle" FillOpacity="0.6" Text="@Labels[i]" />
            }
        }

        @* Series: optional area fill then the line then points *@
        @for (int s = 0; s < _series.Count; s++)
        {
            string color = ChartPalette.At(s, _series[s].Color);
            string line = _linePath(_series[s].Data);

            @if (Area && !string.IsNullOrEmpty(line))
            {
                <path d="@_areaPath(_series[s].Data)" fill="@color" fill-opacity="0.15" stroke="none" />
            }

            <path d="@line" fill="none" stroke="@color" stroke-width="2"
                  stroke-linejoin="round" stroke-linecap="round" />

            @if (ShowPoints)
            {
                @for (int i = 0; i < _series[s].Data.Count; i++)
                {
                    <circle cx="@(_xAt(i).ToString(_ci))" cy="@(_yAt(_series[s].Data[i]).ToString(_ci))"
                            r="3" fill="var(--color-base-100)" stroke="@color" stroke-width="2" />
                }
            }
        }
    </svg>

    @if (ShowLegend && _series.Count > 1)
    {
        <div class="flex flex-wrap gap-3 mt-2 text-xs">
            @for (int s = 0; s < _series.Count; s++)
            {
                <span class="inline-flex items-center gap-1.5">
                    <span class="inline-block w-3 h-3 rounded-sm" style="@($"background:{ChartPalette.At(s, _series[s].Color)};")"></span>
                    <span class="text-base-content/80">@(_series[s].Name)</span>
                </span>
            }
        </div>
    }
</div>

@code {
    /// <summary>One or more named series to plot.</summary>
    [Parameter] public IReadOnlyList<ChartSeries> Series { get; set; } = new List<ChartSeries>();

    /// <summary>X-axis category labels (index-aligned with each series' values).</summary>
    [Parameter] public IReadOnlyList<string>? Labels { get; set; }

    /// <summary>Fill the area under each line.</summary>
    [Parameter] public bool Area { get; set; }

    /// <summary>Smooth the line with cubic curves instead of straight segments.</summary>
    [Parameter] public bool Smooth { get; set; }

    /// <summary>Draw horizontal gridlines and value labels.</summary>
    [Parameter] public bool ShowGrid { get; set; } = true;

    /// <summary>Draw a marker at each data point.</summary>
    [Parameter] public bool ShowPoints { get; set; } = true;

    /// <summary>Show a legend when more than one series is present.</summary>
    [Parameter] public bool ShowLegend { get; set; } = true;

    /// <summary>CSS width of the chart wrapper.</summary>
    [Parameter] public string? Width { get; set; } = "100%";

    /// <summary>CSS height of the SVG plot area.</summary>
    [Parameter] public string? Height { get; set; } = "16rem";

    /// <summary>Optional heading rendered above the chart.</summary>
    [Parameter] public string? Title { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    // Fixed user-space coordinate system; scaled responsively by the SVG viewBox.
    private const double _w = 600;
    private const double _h = 300;
    private const double _padLeft = 40;
    private const double _padRight = 12;
    private const double _padTop = 12;
    private const double _padBottom = 28;

    private static readonly CultureInfo _ci = CultureInfo.InvariantCulture;

    private IReadOnlyList<ChartSeries> _series => Series ?? new List<ChartSeries>();

    private int _count => _series.Count == 0 ? 0 : _series.Max(s => s.Data?.Count ?? 0);

    private double _min;
    private double _max;
    private List<(double Y, string Label)> _yGrid = new();

    private string _ariaLabel =>
        string.IsNullOrEmpty(Title) ? $"Line chart with {_series.Count} series" : Title!;

    protected override void OnParametersSet()
    {
        // Determine value range across all series, guarding empty/equal data.
        IEnumerable<double> all = _series.SelectMany(s => s.Data ?? new List<double>())
            .Where(v => !double.IsNaN(v) && !double.IsInfinity(v));

        if (all.Any())
        {
            _min = all.Min();
            _max = all.Max();
        }
        else
        {
            _min = 0;
            _max = 1;
        }

        // Include zero baseline so areas read naturally.
        if (_min > 0)
        {
            _min = 0;
        }

        if (Math.Abs(_max - _min) < double.Epsilon)
        {
            _max = _min + 1; // avoid divide-by-zero for flat data
        }

        _yGrid.Clear();
        const int ticks = 4;
        for (int t = 0; t <= ticks; t++)
        {
            double value = _min + (_max - _min) * t / ticks;
            _yGrid.Add((_yAt(value), value.ToString("0.##", _ci)));
        }
    }

    private double _plotLeft => _padLeft;
    private double _plotRight => _w - _padRight;
    private double _plotTop => _padTop;
    private double _plotBottom => _h - _padBottom;

    private double _xAt(int index)
    {
        if (_count <= 1)
        {
            return (_plotLeft + _plotRight) / 2; // single point: center it
        }

        return _plotLeft + (_plotRight - _plotLeft) * index / (_count - 1);
    }

    private double _yAt(double value)
    {
        double ratio = (value - _min) / (_max - _min);
        return _plotBottom - (_plotBottom - _plotTop) * ratio;
    }

    private string _linePath(IReadOnlyList<double> data)
    {
        if (data is null || data.Count == 0)
        {
            return string.Empty;
        }

        List<(double X, double Y)> pts = new();
        for (int i = 0; i < data.Count; i++)
        {
            pts.Add((_xAt(i), _yAt(data[i])));
        }

        if (Smooth && pts.Count > 1)
        {
            return SvgGeometry.SmoothPath(pts, _ci);
        }

        return SvgGeometry.PolyPath(pts, _ci);
    }

    private string _areaPath(IReadOnlyList<double> data)
    {
        string line = _linePath(data);
        if (string.IsNullOrEmpty(line) || data.Count == 0)
        {
            return string.Empty;
        }

        double baseY = _yAt(_min);
        double firstX = _xAt(0);
        double lastX = _xAt(data.Count - 1);
        return $"{line} L {lastX.ToString(_ci)} {baseY.ToString(_ci)} L {firstX.ToString(_ci)} {baseY.ToString(_ci)} Z";
    }

    private string _cls => CssClass.Merge("w-full", Class);

    private string _style
    {
        get
        {
            string dim = string.Empty;
            if (!string.IsNullOrEmpty(Width))
            {
                dim += $"width:{Width};";
            }

            return $"{dim}{Style}";
        }
    }
}
