@namespace ShadBz.BlazorApp.Components.UI

@if (AsChild)
{
    @* When AsChild is true, render only the child content with appropriate attributes *@
    <CascadingValue Value="@GetButtonAttributes()" Name="ButtonAttributes">
        @ChildContent
    </CascadingValue>
}
else
{
    <button @attributes="AdditionalAttributes" 
            class="@CssClass" 
            disabled="@IsDisabled"
            data-disabled="@(IsDisabled ? "" : null)"
            data-accent-color="@Color"
            data-radius="@Radius"
            @onclick="OnClick">
        @if (Loading)
        {
            @* Loading state with spinner *@
            <span style="display: contents; visibility: hidden;" aria-hidden="true">
                @ChildContent
            </span>
            <span class="visually-hidden">@ChildContent</span>
            <span class="rt-Flex" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;">
                <span class="rt-Spinner @GetSpinnerSizeClass()"></span>
            </span>
        }
        else
        {
            @ChildContent
        }
    </button>
}

@code {
    private Dictionary<string, object> GetButtonAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["class"] = CssClass,
            ["disabled"] = IsDisabled
        };
        
        if (IsDisabled)
            attributes["data-disabled"] = "";
            
        if (!string.IsNullOrEmpty(Color))
            attributes["data-accent-color"] = Color;
            
        if (!string.IsNullOrEmpty(Radius))
            attributes["data-radius"] = Radius;
            
        if (OnClick.HasDelegate)
            attributes["onclick"] = OnClick;
            
        // Merge with additional attributes
        if (AdditionalAttributes != null)
        {
            foreach (var attr in AdditionalAttributes)
            {
                attributes[attr.Key] = attr.Value;
            }
        }
        
        return attributes;
    }
}