@namespace ShadBz.BlazorApp.Components.UI
@inherits ShadBz.BlazorApp.Components.UI.Base.SpacingComponentBase

@if (AsChild)
{
    @ChildContent
}
else
{
    <code class="@CodeCssClass" @attributes="AdditionalAttributes">@ChildContent</code>
}

@code {
    [Parameter] public new RenderFragment? ChildContent { get; set; }
    [Parameter] public bool AsChild { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public new Dictionary<string, object>? AdditionalAttributes { get; set; }
    
    private string CodeCssClass => new CssBuilder("rt-Code")
        .AddClass($"rt-r-size-{((int)Size) + 1}")
        .AddClass($"rt-variant-{Variant.ToString().ToLower()}")
        .AddClass($"rt-r-weight-{Weight.ToString().ToLower()}")
        .AddClass($"rt-color-{Color?.ToLower() ?? "gray"}")
        .AddClass("rt-high-contrast", HighContrast)
        .AddClass(GetMarginClasses())
        .AddClass(Class)
        .Build();
}