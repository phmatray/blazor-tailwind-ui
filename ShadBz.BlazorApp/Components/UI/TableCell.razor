@namespace ShadBz.BlazorApp.Components.UI
@inherits ComponentBase

@if (IsHeader)
{
    <th class="@CellCssClass" style="@GetStyle()" @attributes="AdditionalAttributes">
        @ChildContent
    </th>
}
else
{
    <td class="@CellCssClass" style="@GetStyle()" @attributes="AdditionalAttributes">
        @ChildContent
    </td>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool IsHeader { get; set; }
    [Parameter] public TableCellAlign? Align { get; set; }
    [Parameter] public string? Width { get; set; }
    [Parameter] public string? MinWidth { get; set; }
    [Parameter] public string? MaxWidth { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
    
    private string CellCssClass => new CssBuilder(IsHeader ? "rt-TableHeaderCell" : "rt-TableCell")
        .AddClass(GetAlignClass())
        .Build();
    
    private string GetAlignClass() => Align switch
    {
        TableCellAlign.Left => "rt-align-left",
        TableCellAlign.Center => "rt-align-center",
        TableCellAlign.Right => "rt-align-right",
        _ => ""
    };
    
    private string GetStyle()
    {
        var style = "";
        
        if (!string.IsNullOrEmpty(Width))
            style += $"width: {Width}; ";
        if (!string.IsNullOrEmpty(MinWidth))
            style += $"min-width: {MinWidth}; ";
        if (!string.IsNullOrEmpty(MaxWidth))
            style += $"max-width: {MaxWidth}; ";
            
        return style.Trim();
    }
}