@namespace ShadBz.BlazorApp.Components.UI
@inherits ShadBz.BlazorApp.Components.UI.Base.SpacingComponentBase

<div @attributes="GetRootAttributes()">
    <textarea 
        class="rt-reset rt-TextAreaInput"
        value="@Value"
        @onchange="HandleChange"
        @oninput="HandleInput"
        placeholder="@Placeholder"
        disabled="@Disabled"
        readonly="@ReadOnly"
        required="@Required"
        rows="@Rows"
        cols="@Cols"
        minlength="@MinLength"
        maxlength="@MaxLength"
        name="@Name"
        id="@Id"
        autocomplete="@AutoComplete"
        spellcheck="@SpellCheck"
        wrap="@Wrap"
        style="@GetTextAreaStyle()"
        @attributes="AdditionalAttributes">@Value</textarea>
</div>