@namespace ShadBz.BlazorApp.Components.UI
@inherits ShadBz.BlazorApp.Components.UI.Base.SpacingComponentBase

<div @ref="_sliderElement" @attributes="GetSliderAttributes()">
    <div class="rt-SliderTrack">
        <div class="rt-SliderRange" style="@GetRangeStyle()"></div>
    </div>
    @if (IsRange)
    {
        <div class="rt-SliderThumb" 
             style="@GetThumbStyle(0)" 
             @onmousedown="@(e => StartDrag(e, 0))"
             @ontouchstart="@(e => StartTouchDrag(e, 0))"
             tabindex="0"
             role="slider"
             aria-valuemin="@Min"
             aria-valuemax="@Max"
             aria-valuenow="@Values[0]"
             aria-label="@(AriaLabel ?? "Minimum value")">
        </div>
        <div class="rt-SliderThumb" 
             style="@GetThumbStyle(1)" 
             @onmousedown="@(e => StartDrag(e, 1))"
             @ontouchstart="@(e => StartTouchDrag(e, 1))"
             tabindex="0"
             role="slider"
             aria-valuemin="@Min"
             aria-valuemax="@Max"
             aria-valuenow="@Values[1]"
             aria-label="@(AriaLabel ?? "Maximum value")">
        </div>
    }
    else
    {
        <div class="rt-SliderThumb" 
             style="@GetThumbStyle(0)" 
             @onmousedown="@(e => StartDrag(e, 0))"
             @ontouchstart="@(e => StartTouchDrag(e, 0))"
             tabindex="0"
             role="slider"
             aria-valuemin="@Min"
             aria-valuemax="@Max"
             aria-valuenow="@Values[0]"
             aria-label="@AriaLabel">
        </div>
    }
</div>