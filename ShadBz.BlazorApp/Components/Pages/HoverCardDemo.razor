@page "/hovercard"
@using ShadBz.BlazorApp.Components.UI

<div class="demo-container">
    <h1>HoverCard Component</h1>
    <p>For sighted users to preview content available behind a link.</p>
    
    <div class="demo-section">
        <h2>Basic HoverCard</h2>
        <div class="demo-example">
            <HoverCardRoot>
                <HoverCardTrigger>
                    <Link Size="LinkSize.Size2" Underline="LinkUnderline.Hover">
                        @("@radix-ui")
                    </Link>
                </HoverCardTrigger>
                <HoverCardContent>
                    <Flex Gap="FlexGap.Gap3">
                        <Avatar Size="AvatarSize.Size3">
                            <Fallback>R</Fallback>
                        </Avatar>
                        <Box>
                            <Heading Size="HeadingSize.Size3" As="h3">Radix UI</Heading>
                            <Text As="div" Size="TextSize.Size2" Color="TextColor.Gray">
                                @("@radix-ui")
                            </Text>
                            <Text As="div" Size="TextSize.Size2" Mt="3">
                                Components, icons, colors, and templates for building high-quality, accessible UI.
                            </Text>
                        </Box>
                    </Flex>
                </HoverCardContent>
            </HoverCardRoot>
        </div>
    </div>
    
    <div class="demo-section">
        <h2>With Profile Card</h2>
        <div class="demo-example">
            <Text>
                Follow
                <HoverCardRoot>
                    <HoverCardTrigger>
                        <Link Size="LinkSize.Size2" Underline="LinkUnderline.Hover">
                            @("@phmatray")
                        </Link>
                    </HoverCardTrigger>
                    <HoverCardContent Width="300px">
                        <Flex Gap="FlexGap.Gap4">
                            <Avatar Size="AvatarSize.Size3">
                                <Fallback>PM</Fallback>
                            </Avatar>
                            <Box Style="flex: 1;">
                                <Flex Direction="FlexDirection.Column" Gap="FlexGap.Gap3">
                                    <div>
                                        <Heading Size="HeadingSize.Size3" As="h3">Philippe Matray</Heading>
                                        <Text As="div" Size="TextSize.Size2" Color="TextColor.Gray">
                                            @("@phmatray")
                                        </Text>
                                    </div>
                                    <Text As="div" Size="TextSize.Size2">
                                        Full-stack developer and open source enthusiast. Building modern web applications.
                                    </Text>
                                    <Flex Gap="FlexGap.Gap3" Mt="3">
                                        <Flex Gap="FlexGap.Gap1">
                                            <Text Size="TextSize.Size2" Weight="TextWeight.Bold">0</Text>
                                            <Text Size="TextSize.Size2" Color="TextColor.Gray">Following</Text>
                                        </Flex>
                                        <Flex Gap="FlexGap.Gap1">
                                            <Text Size="TextSize.Size2" Weight="TextWeight.Bold">2,900</Text>
                                            <Text Size="TextSize.Size2" Color="TextColor.Gray">Followers</Text>
                                        </Flex>
                                    </Flex>
                                </Flex>
                            </Box>
                        </Flex>
                    </HoverCardContent>
                </HoverCardRoot>
                on GitHub for more updates.
            </Text>
        </div>
    </div>
    
    <div class="demo-section">
        <h2>With Custom Delays</h2>
        <div class="demo-example">
            <Flex Gap="FlexGap.Gap4">
                <HoverCardRoot OpenDelay="200" CloseDelay="100">
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Soft">Quick (200ms)</Button>
                    </HoverCardTrigger>
                    <HoverCardContent>
                        <Text Size="TextSize.Size2">
                            This hover card appears quickly with a 200ms delay.
                        </Text>
                    </HoverCardContent>
                </HoverCardRoot>
                
                <HoverCardRoot OpenDelay="1000" CloseDelay="500">
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Soft">Slow (1000ms)</Button>
                    </HoverCardTrigger>
                    <HoverCardContent>
                        <Text Size="TextSize.Size2">
                            This hover card appears slowly with a 1000ms delay.
                        </Text>
                    </HoverCardContent>
                </HoverCardRoot>
            </Flex>
        </div>
    </div>
    
    <div class="demo-section">
        <h2>Different Sides</h2>
        <div class="demo-example">
            <Flex Gap="FlexGap.Gap4" Align="FlexAlign.Center" Style="padding: 60px;">
                <HoverCardRoot>
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Outline">Top</Button>
                    </HoverCardTrigger>
                    <HoverCardContent Side="HoverCardSide.Top">
                        <Text Size="TextSize.Size2">Content appears above</Text>
                    </HoverCardContent>
                </HoverCardRoot>
                
                <HoverCardRoot>
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Outline">Right</Button>
                    </HoverCardTrigger>
                    <HoverCardContent Side="HoverCardSide.Right">
                        <Text Size="TextSize.Size2">Content appears to the right</Text>
                    </HoverCardContent>
                </HoverCardRoot>
                
                <HoverCardRoot>
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Outline">Bottom</Button>
                    </HoverCardTrigger>
                    <HoverCardContent Side="HoverCardSide.Bottom">
                        <Text Size="TextSize.Size2">Content appears below</Text>
                    </HoverCardContent>
                </HoverCardRoot>
                
                <HoverCardRoot>
                    <HoverCardTrigger>
                        <Button Variant="ButtonVariant.Outline">Left</Button>
                    </HoverCardTrigger>
                    <HoverCardContent Side="HoverCardSide.Left">
                        <Text Size="TextSize.Size2">Content appears to the left</Text>
                    </HoverCardContent>
                </HoverCardRoot>
            </Flex>
        </div>
    </div>
    
    <div class="demo-section">
        <h2>With Rich Content</h2>
        <div class="demo-example">
            <HoverCardRoot>
                <HoverCardTrigger>
                    <Card Style="width: 200px; cursor: pointer;">
                        <Flex Direction="FlexDirection.Column" Gap="FlexGap.Gap2">
                            <Heading Size="HeadingSize.Size3">Project Stats</Heading>
                            <Text Size="TextSize.Size2" Color="TextColor.Gray">Hover for details</Text>
                        </Flex>
                    </Card>
                </HoverCardTrigger>
                <HoverCardContent Width="400px">
                    <Flex Direction="FlexDirection.Column" Gap="FlexGap.Gap3">
                        <Heading Size="HeadingSize.Size4">Detailed Statistics</Heading>
                        <Grid Columns="2" Gap="GridGap.Gap3">
                            <Box>
                                <Text Size="TextSize.Size1" Color="TextColor.Gray">Total Users</Text>
                                <Text Size="TextSize.Size5" Weight="TextWeight.Bold">12,543</Text>
                            </Box>
                            <Box>
                                <Text Size="TextSize.Size1" Color="TextColor.Gray">Active Sessions</Text>
                                <Text Size="TextSize.Size5" Weight="TextWeight.Bold">1,234</Text>
                            </Box>
                            <Box>
                                <Text Size="TextSize.Size1" Color="TextColor.Gray">Revenue</Text>
                                <Text Size="TextSize.Size5" Weight="TextWeight.Bold">$45,678</Text>
                            </Box>
                            <Box>
                                <Text Size="TextSize.Size1" Color="TextColor.Gray">Growth</Text>
                                <Text Size="TextSize.Size5" Weight="TextWeight.Bold" Color="TextColor.Green">+23%</Text>
                            </Box>
                        </Grid>
                        <Separator Size="SeparatorSize.Size2" />
                        <Text Size="TextSize.Size2" Color="TextColor.Gray">
                            Last updated: 5 minutes ago
                        </Text>
                    </Flex>
                </HoverCardContent>
            </HoverCardRoot>
        </div>
    </div>
</div>

<style>
    .demo-container {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .demo-section {
        margin-bottom: 3rem;
    }
    
    .demo-section h2 {
        margin-bottom: 1rem;
        font-size: 1.5rem;
        font-weight: 600;
    }
    
    .demo-example {
        padding: 2rem;
        background: var(--gray-2);
        border-radius: var(--radius-3);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
    }
</style>