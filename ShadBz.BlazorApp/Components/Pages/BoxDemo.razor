@page "/box-demo"
@using ShadBz.BlazorApp.Components.UI

<PageTitle>Box Demo</PageTitle>

<div class="demo-container">
    <h1>Box Component Demo</h1>

    <div class="demo-section">
        <h2>Basic Box Usage</h2>
        <Box P="4" style="background: var(--gray-a3); border-radius: var(--radius-3);">
            This is a basic Box with padding
        </Box>
    </div>

    <div class="demo-section">
        <h2>As Prop (div vs span)</h2>
        <div style="display: flex; gap: var(--space-3); align-items: center;">
            <Box As="div" P="3" style="background: var(--blue-a3); border-radius: var(--radius-2);">
                I'm a div (block)
            </Box>
            <Box As="span" P="3" style="background: var(--green-a3); border-radius: var(--radius-2);">
                I'm a span (inline)
            </Box>
        </div>
    </div>

    <div class="demo-section">
        <h2>Display Values</h2>
        <div style="display: flex; gap: var(--space-2); flex-wrap: wrap;">
            <Box Display="inline-block" P="2" style="background: var(--amber-a3);">inline-block</Box>
            <Box Display="inline" P="2" style="background: var(--purple-a3);">inline</Box>
            <Box Display="block" P="2" style="background: var(--red-a3);">block</Box>
        </div>
    </div>

    <div class="demo-section">
        <h2>Margin Examples</h2>
        <div style="background: var(--gray-a2); padding: var(--space-4);">
            <Box M="0" P="3" style="background: var(--blue-3);">No margin (M="0")</Box>
            <Box M="2" P="3" style="background: var(--green-3);">Margin 2 all sides</Box>
            <Box Mx="4" My="2" P="3" style="background: var(--amber-3);">Margin X=4, Y=2</Box>
            <Box Mt="3" Mb="3" P="3" style="background: var(--purple-3);">Margin top & bottom = 3</Box>
        </div>
    </div>

    <div class="demo-section">
        <h2>Padding Examples</h2>
        <Box P="1" Mb="2" style="background: var(--red-a3);">Padding 1</Box>
        <Box P="2" Mb="2" style="background: var(--blue-a3);">Padding 2</Box>
        <Box P="3" Mb="2" style="background: var(--green-a3);">Padding 3</Box>
        <Box P="4" Mb="2" style="background: var(--amber-a3);">Padding 4</Box>
        <Box P="5" Mb="2" style="background: var(--purple-a3);">Padding 5</Box>
        <Box Px="6" Py="2" style="background: var(--cyan-a3);">Padding X=6, Y=2</Box>
    </div>

    <div class="demo-section">
        <h2>Size Properties</h2>
        <Box Width="200px" Height="100px" P="3" style="background: var(--blue-a3); border: 1px solid var(--blue-6);">
            Fixed Width & Height (200px × 100px)
        </Box>
        <Box Width="50%" Mt="3" P="3" style="background: var(--green-a3); border: 1px solid var(--green-6);">
            50% Width
        </Box>
        <Box MinWidth="300px" MaxWidth="500px" Mt="3" P="3" style="background: var(--amber-a3); border: 1px solid var(--amber-6);">
            Min Width: 300px, Max Width: 500px (resize window to see effect)
        </Box>
    </div>

    <div class="demo-section">
        <h2>Position Examples</h2>
        <Box Position="relative" Height="200px" P="3" style="background: var(--gray-a2); border: 1px solid var(--gray-6);">
            <span>Parent (relative)</span>
            <Box Position="absolute" Top="2" Right="2" P="2" style="background: var(--red-3); border-radius: var(--radius-2);">
                Top Right
            </Box>
            <Box Position="absolute" Bottom="2" Left="2" P="2" style="background: var(--blue-3); border-radius: var(--radius-2);">
                Bottom Left
            </Box>
            <Box Position="absolute" Inset="0" Display="flex" style="align-items: center; justify-content: center;">
                <Box P="2" style="background: var(--green-3); border-radius: var(--radius-2);">
                    Centered (inset=0 + flex)
                </Box>
            </Box>
        </Box>
    </div>

    <div class="demo-section">
        <h2>Overflow Control</h2>
        <Box Width="200px" Height="100px" Overflow="auto" P="3" style="background: var(--purple-a2); border: 1px solid var(--purple-6);">
            <Box Width="300px">
                This content is wider than the container.
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                The container has overflow="auto" so it will scroll.
            </Box>
        </Box>
    </div>

    <div class="demo-section">
        <h2>Flexbox Properties</h2>
        <div style="display: flex; gap: var(--space-2); height: 100px; background: var(--gray-a2); padding: var(--space-2);">
            <Box FlexGrow="0" FlexShrink="0" P="2" style="background: var(--red-3);">
                No grow/shrink
            </Box>
            <Box FlexGrow="1" P="2" style="background: var(--blue-3);">
                Flex grow = 1
            </Box>
            <Box FlexGrow="1" AlignSelf="center" P="2" style="background: var(--green-3);">
                Flex grow = 1, align-self = center
            </Box>
            <Box AlignSelf="end" P="2" style="background: var(--amber-3);">
                Align-self = end
            </Box>
        </div>
    </div>

    <div class="demo-section">
        <h2>Grid Properties</h2>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-2); background: var(--gray-a2); padding: var(--space-2);">
            <Box GridColumn="span 2" P="3" style="background: var(--blue-3);">
                Spans 2 columns
            </Box>
            <Box P="3" style="background: var(--green-3);">
                Normal
            </Box>
            <Box P="3" style="background: var(--amber-3);">
                Normal
            </Box>
            <Box GridColumn="span 3" P="3" style="background: var(--purple-3);">
                Spans all 3 columns
            </Box>
        </div>
    </div>

    <div class="demo-section">
        <h2>Custom Values (non-space-scale)</h2>
        <Box Width="calc(100% - 40px)" P="20px" M="20px" style="background: var(--cyan-a3); border: 2px dashed var(--cyan-6);">
            Using custom CSS values: width="calc(100% - 40px)", padding="20px", margin="20px"
        </Box>
    </div>

    <div class="demo-section">
        <h2>Nested Boxes</h2>
        <Box P="4" style="background: var(--gray-a3); border-radius: var(--radius-3);">
            <Box P="3" Mb="3" style="background: var(--blue-a3); border-radius: var(--radius-2);">
                <Box P="2" style="background: var(--blue-a4); border-radius: var(--radius-1);">
                    Deeply nested Box components
                </Box>
            </Box>
            <Box P="3" style="background: var(--green-a3); border-radius: var(--radius-2);">
                Another nested Box
            </Box>
        </Box>
    </div>

    <div class="demo-section">
        <h2>Responsive Design (Simulated)</h2>
        <Box 
            P="2" 
            Width="100%" 
            style="background: var(--purple-a3); border-radius: var(--radius-2);">
            This Box could have responsive props in a full implementation
        </Box>
    </div>
</div>

<style>
    .demo-container {
        padding: var(--space-4);
        max-width: 1200px;
        margin: 0 auto;
    }

    .demo-section {
        margin-bottom: var(--space-6);
    }

    .demo-section h2 {
        margin-bottom: var(--space-3);
        font-size: var(--font-size-4);
        font-weight: var(--font-weight-bold);
        color: var(--gray-12);
    }
</style>