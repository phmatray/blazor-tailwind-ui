@page "/button-demo"
@using ShadBz.BlazorApp.Components.UI

<PageTitle>Button Demo</PageTitle>

<div class="demo-container">
    <h1>Button Component Demo</h1>

    <div class="demo-section">
        <h2>Sizes</h2>
        <div class="button-group">
            <Button Size="ButtonSize.Small">Size 1</Button>
            <Button Size="ButtonSize.Medium">Size 2</Button>
            <Button Size="ButtonSize.Large">Size 3</Button>
            <Button Size="ButtonSize.ExtraLarge">Size 4</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Variants</h2>
        <div class="button-group">
            <Button Variant="ButtonVariant.Classic">Classic</Button>
            <Button Variant="ButtonVariant.Solid">Solid</Button>
            <Button Variant="ButtonVariant.Soft">Soft</Button>
            <Button Variant="ButtonVariant.Surface">Surface</Button>
            <Button Variant="ButtonVariant.Outline">Outline</Button>
            <Button Variant="ButtonVariant.Ghost">Ghost</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Colors</h2>
        <div class="button-group">
            <Button Color="gray">Gray</Button>
            <Button Color="gold">Gold</Button>
            <Button Color="bronze">Bronze</Button>
            <Button Color="brown">Brown</Button>
            <Button Color="yellow">Yellow</Button>
            <Button Color="amber">Amber</Button>
            <Button Color="orange">Orange</Button>
            <Button Color="tomato">Tomato</Button>
            <Button Color="red">Red</Button>
            <Button Color="ruby">Ruby</Button>
            <Button Color="crimson">Crimson</Button>
            <Button Color="pink">Pink</Button>
            <Button Color="plum">Plum</Button>
            <Button Color="purple">Purple</Button>
            <Button Color="violet">Violet</Button>
            <Button Color="iris">Iris</Button>
            <Button Color="indigo">Indigo</Button>
            <Button Color="blue">Blue</Button>
            <Button Color="cyan">Cyan</Button>
            <Button Color="teal">Teal</Button>
            <Button Color="jade">Jade</Button>
            <Button Color="green">Green</Button>
            <Button Color="grass">Grass</Button>
            <Button Color="lime">Lime</Button>
            <Button Color="mint">Mint</Button>
            <Button Color="sky">Sky</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>High Contrast</h2>
        <div class="button-group">
            <Button HighContrast="false">Normal</Button>
            <Button HighContrast="true">High Contrast</Button>
            <Button Variant="ButtonVariant.Classic" HighContrast="false">Classic Normal</Button>
            <Button Variant="ButtonVariant.Classic" HighContrast="true">Classic High Contrast</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Radius</h2>
        <div class="button-group">
            <Button Radius="none">None</Button>
            <Button Radius="small">Small</Button>
            <Button Radius="medium">Medium</Button>
            <Button Radius="large">Large</Button>
            <Button Radius="full">Full</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>States</h2>
        <div class="button-group">
            <Button>Normal</Button>
            <Button Disabled="true">Disabled</Button>
            <Button Loading="true">Loading</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Loading States with Different Sizes</h2>
        <div class="button-group">
            <Button Size="ButtonSize.Small" Loading="true">Small Loading</Button>
            <Button Size="ButtonSize.Medium" Loading="true">Medium Loading</Button>
            <Button Size="ButtonSize.Large" Loading="true">Large Loading</Button>
            <Button Size="ButtonSize.ExtraLarge" Loading="true">Extra Large Loading</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>With Icons (Simulated)</h2>
        <div class="button-group">
            <Button>
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 2.75C8 2.47386 7.77614 2.25 7.5 2.25C7.22386 2.25 7 2.47386 7 2.75V7H2.75C2.47386 7 2.25 7.22386 2.25 7.5C2.25 7.77614 2.47386 8 2.75 8H7V12.25C7 12.5261 7.22386 12.75 7.5 12.75C7.77614 12.75 8 12.5261 8 12.25V8H12.25C12.5261 8 12.75 7.77614 12.75 7.5C12.75 7.22386 12.5261 7 12.25 7H8V2.75Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path>
                </svg>
                Add Item
            </Button>
            <Button Variant="ButtonVariant.Soft">
                Edit
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11.8536 1.14645C11.6583 0.951184 11.3417 0.951184 11.1464 1.14645L3.71068 8.58214C3.62004 8.67278 3.55263 8.78362 3.51412 8.90583L2.05255 13.3199C1.98595 13.5266 2.02896 13.7532 2.16517 13.9177C2.30137 14.0822 2.51113 14.1593 2.71401 14.0932L7.09366 12.6319C7.21578 12.5934 7.32662 12.526 7.41726 12.4354L14.8536 5.00001C15.0488 4.80475 15.0488 4.48816 14.8536 4.2929L10.7071 0.146452C10.5119 -0.0488137 10.1953 -0.0488137 10 0.146452L11.8536 1.14645ZM7.12132 11.7176L4.08754 12.7917L5.16151 9.75787L11.5 3.41937L10.5808 2.50023L4.24229 8.83873L7.12132 11.7176Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path>
                </svg>
            </Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Ghost Variant with Margins</h2>
        <div class="button-group" style="background: var(--gray-a3); padding: var(--space-4); border-radius: var(--radius-3);">
            <Button Variant="ButtonVariant.Ghost">No margin</Button>
            <Button Variant="ButtonVariant.Ghost" M="2">Margin 2</Button>
            <Button Variant="ButtonVariant.Ghost" Mx="3">Margin X 3</Button>
            <Button Variant="ButtonVariant.Ghost" My="2">Margin Y 2</Button>
        </div>
    </div>

    <div class="demo-section">
        <h2>Interactive Example</h2>
        <div class="button-group">
            <Button OnClick="HandleClick">Click Me</Button>
            <Button Variant="ButtonVariant.Soft" OnClick="HandleReset">Reset</Button>
            <span>Clicked: @clickCount times</span>
        </div>
    </div>

    <div class="demo-section">
        <h2>All Variants with Colors</h2>
        @foreach (var variant in Enum.GetValues<ButtonVariant>())
        {
            <h3>@variant</h3>
            <div class="button-group">
                <Button Variant="variant" Color="blue">Blue</Button>
                <Button Variant="variant" Color="green">Green</Button>
                <Button Variant="variant" Color="red">Red</Button>
                <Button Variant="variant" Color="purple">Purple</Button>
                <Button Variant="variant" Color="amber">Amber</Button>
            </div>
        }
    </div>
</div>

@code {
    private int clickCount = 0;

    private void HandleClick()
    {
        clickCount++;
    }
    
    private void HandleReset()
    {
        clickCount = 0;
    }
}

<style>
    .demo-container {
        padding: var(--space-4);
        max-width: 1200px;
        margin: 0 auto;
    }

    .demo-section {
        margin-bottom: var(--space-6);
    }

    .demo-section h2 {
        margin-bottom: var(--space-3);
        font-size: var(--font-size-4);
        font-weight: var(--font-weight-bold);
        color: var(--gray-12);
    }
    
    .demo-section h3 {
        margin-top: var(--space-3);
        margin-bottom: var(--space-2);
        font-size: var(--font-size-2);
        font-weight: var(--font-weight-medium);
        color: var(--gray-11);
    }

    .button-group {
        display: flex;
        gap: var(--space-2);
        align-items: center;
        flex-wrap: wrap;
    }
</style>