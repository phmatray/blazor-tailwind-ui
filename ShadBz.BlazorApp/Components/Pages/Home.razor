@page "/"
@using ShadBz.BlazorApp.Components.UI

<PageTitle>Radix UI Blazor Components</PageTitle>

<Section Size="SectionSize.Size3">
    <Container Size="ContainerSize.Size4">
        <Flex Direction="FlexDirection.Column" Gap="6">
            <Box>
                <Heading Size="8" Weight="TextWeight.Bold" Align="TextAlign.Center" Mb="2">
                    Radix UI for Blazor
                </Heading>
                <Text Size="5" Align="TextAlign.Center" Color="gray">
                    A comprehensive port of Radix UI components to Blazor
                </Text>
            </Box>

            <Box Mt="6">
                <Heading Size="6" Weight="TextWeight.Medium" Mb="4">
                    Component Demos
                </Heading>
                
                <Grid Columns="3" Gap="4">
                    @RenderCard("Button", "Interactive button component with multiple variants and sizes", "/button-demo", true)
                    @RenderCard("Box", "Fundamental layout component with flexible styling options", "/box-demo", true)
                    @RenderCard("Text", "Typography component for rendering text with various styles", "/text-demo", true)
                    @RenderCard("Heading", "Semantic heading component with size and weight variants", "/heading-demo", true)
                    @RenderCard("Flex", "Flexbox layout component for flexible arrangements", "/flex-demo", true)
                    @RenderCard("Grid", "CSS Grid layout component for complex layouts", "/grid-demo", true)
                    @RenderCard("Container", "Responsive container with max-width constraints", "/container-demo", true)
                    @RenderCard("Section", "Semantic section component with vertical spacing", "/section-demo", true)
                    @RenderCard("Card", "Container component for grouping related content", "/card-demo", true)
                    @RenderCard("Link", "Text-based navigation component with underline styles", "/link-demo", true)
                    @RenderCard("Avatar", "User avatar with image fallback and initials", "/avatar-demo", true)
                    @RenderCard("Badge", "Small label component for status and counts", "/badge-demo", true)
                </Grid>
            </Box>

            <Box Mt="6">
                <Heading Size="6" Weight="TextWeight.Medium" Mb="4">
                    Coming Soon
                </Heading>
                
                <Grid Columns="3" Gap="4">
                    @RenderCard("Callout", "Informational panel with icon support", null, false)
                    @RenderCard("Dialog", "Modal dialog for important interactions", null, false)
                    @RenderCard("Select", "Customizable dropdown selection component", null, false)
                    @RenderCard("Table", "Data table with sorting and filtering", null, false)
                </Grid>
            </Box>

            <Box Mt="6">
                <Heading Size="6" Weight="TextWeight.Medium" Mb="4">
                    Project Status
                </Heading>
                
                <Flex Direction="FlexDirection.Column" Gap="3">
                    <Flex Align="FlexAlign.Center" Gap="2">
                        <Box Width="4" Height="4" Style="background: var(--green-9); border-radius: var(--radius-1);"></Box>
                        <Text Size="3">12 Components Completed</Text>
                    </Flex>
                    <Flex Align="FlexAlign.Center" Gap="2">
                        <Box Width="4" Height="4" Style="background: var(--gray-6); border-radius: var(--radius-1);"></Box>
                        <Text Size="3">28 Components Pending</Text>
                    </Flex>
                    <Flex Align="FlexAlign.Center" Gap="2">
                        <Box Width="4" Height="4" Style="background: var(--blue-9); border-radius: var(--radius-1);"></Box>
                        <Text Size="3">Code refactored with shared base classes</Text>
                    </Flex>
                </Flex>
            </Box>
        </Flex>
    </Container>
</Section>

@code {
    private RenderFragment RenderCard(string title, string description, string? href, bool isCompleted)
    {
        return builder =>
        {
            builder.OpenComponent<Box>(0);
            builder.AddAttribute(1, "P", "4");
            builder.AddAttribute(2, "Style", $"background: var(--gray-2); border-radius: var(--radius-3); border: 1px solid var(--gray-4); height: 100%; {(isCompleted ? "" : "opacity: 0.6;")}");
            builder.AddAttribute(3, "ChildContent", (RenderFragment)(builder2 =>
            {
                builder2.OpenComponent<Flex>(4);
                builder2.AddAttribute(5, "Direction", FlexDirection.Column);
                builder2.AddAttribute(6, "Gap", "2");
                builder2.AddAttribute(7, "Height", "100%");
                builder2.AddAttribute(8, "ChildContent", (RenderFragment)(builder3 =>
                {
                    // Title
                    builder3.OpenComponent<Heading>(9);
                    builder3.AddAttribute(10, "Size", "4");
                    builder3.AddAttribute(11, "Weight", TextWeight.Medium);
                    builder3.AddAttribute(12, "ChildContent", (RenderFragment)(builder4 =>
                    {
                        builder4.AddContent(13, title);
                    }));
                    builder3.CloseComponent();

                    // Description
                    builder3.OpenComponent<Text>(14);
                    builder3.AddAttribute(15, "Size", "2");
                    builder3.AddAttribute(16, "Color", "gray");
                    builder3.AddAttribute(17, "ChildContent", (RenderFragment)(builder4 =>
                    {
                        builder4.AddContent(18, description);
                    }));
                    builder3.CloseComponent();

                    // Link (if provided)
                    if (!string.IsNullOrEmpty(href))
                    {
                        builder3.OpenComponent<Box>(19);
                        builder3.AddAttribute(20, "Mt", "auto");
                        builder3.AddAttribute(21, "ChildContent", (RenderFragment)(builder4 =>
                        {
                            builder4.OpenElement(22, "a");
                            builder4.AddAttribute(23, "href", href);
                            builder4.AddAttribute(24, "style", "color: var(--accent-9); text-decoration: none; font-size: var(--font-size-2);");
                            builder4.AddContent(25, "View Demo →");
                            builder4.CloseElement();
                        }));
                        builder3.CloseComponent();
                    }
                }));
                builder2.CloseComponent();
            }));
            builder.CloseComponent();
        };
    }
}