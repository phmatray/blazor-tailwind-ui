@page "/demos/dialog"
@using ShadBz.BlazorApp.Components.UI

<PageTitle>Dialog Component - Radix UI Blazor</PageTitle>

<Container Size="ContainerSize.Size4">
    <Section Size="SectionSize.Size3">
        <Flex Direction="FlexDirection.Column" Gap="6">
            <!-- Header -->
            <Box>
                <Heading Size="HeadingSize.Size8" Mb="2">Dialog</Heading>
                <Text Size="4" Color="gray">
                    A modal dialog that interrupts the user with important content and expects a response.
                </Text>
            </Box>

            <!-- Basic Dialog -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Basic Dialog</Heading>
                <Card>
                    <DialogRoot>
                        <DialogTrigger>
                            <Button>Open Dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogTitle>Edit Profile</DialogTitle>
                            <DialogDescription>
                                Make changes to your profile here. Click save when you're done.
                            </DialogDescription>
                            
                            <Flex Direction="FlexDirection.Column" Gap="3" Mt="4">
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Name</Text>
                                    <TextFieldRoot Size="TextFieldSize.Size2" Value="Pedro Duarte" />
                                </Box>
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Username</Text>
                                    <TextFieldRoot Size="TextFieldSize.Size2" Value="@("@pedroduarte")" />
                                </Box>
                            </Flex>
                            
                            <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                <DialogClose AsChild="true">
                                    <Button Variant="ButtonVariant.Soft">Cancel</Button>
                                </DialogClose>
                                <Button>Save changes</Button>
                            </Flex>
                        </DialogContent>
                    </DialogRoot>
                </Card>
            </Box>

            <!-- Dialog Sizes -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Dialog Sizes</Heading>
                <Card>
                    <Flex Gap="3" Wrap="FlexWrap.Wrap">
                        @foreach (var size in Enum.GetValues<DialogSize>())
                        {
                            <DialogRoot>
                                <DialogTrigger>
                                    <Button Variant="ButtonVariant.Outline">@size</Button>
                                </DialogTrigger>
                                <DialogContent Size="@size">
                                    <DialogTitle>@size Dialog</DialogTitle>
                                    <DialogDescription>
                                        This is a @size sized dialog. Notice how the width changes based on the size.
                                    </DialogDescription>
                                    <Box Mt="4">
                                        <Text Size="2">
                                            Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
                                            Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                        </Text>
                                    </Box>
                                    <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                        <DialogClose AsChild="true">
                                            <Button>Close</Button>
                                        </DialogClose>
                                    </Flex>
                                </DialogContent>
                            </DialogRoot>
                        }
                    </Flex>
                </Card>
            </Box>

            <!-- Controlled Dialog -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Controlled Dialog</Heading>
                <Card>
                    <Flex Direction="FlexDirection.Column" Gap="3">
                        <Flex Gap="2" Align="FlexAlign.Center">
                            <Switch @bind-Checked="_isDialogOpen" />
                            <Text Size="2">Dialog is @(_isDialogOpen ? "open" : "closed")</Text>
                        </Flex>
                        
                        <DialogRoot @bind-Open="_isDialogOpen">
                            <DialogTrigger>
                                <Button>Open Controlled Dialog</Button>
                            </DialogTrigger>
                            <DialogContent>
                                <DialogTitle>Controlled Dialog</DialogTitle>
                                <DialogDescription>
                                    This dialog's open state is controlled by the parent component.
                                </DialogDescription>
                                <Text Size="2" Mt="4">
                                    You can toggle the dialog using the switch above or close it normally.
                                </Text>
                                <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                    <DialogClose AsChild="true">
                                        <Button>Close</Button>
                                    </DialogClose>
                                </Flex>
                            </DialogContent>
                        </DialogRoot>
                    </Flex>
                </Card>
            </Box>

            <!-- Non-Modal Dialog -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Non-Modal Dialog</Heading>
                <Card>
                    <DialogRoot Modal="false">
                        <DialogTrigger>
                            <Button Variant="ButtonVariant.Soft">Open Non-Modal Dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogTitle>Non-Modal Dialog</DialogTitle>
                            <DialogDescription>
                                This dialog doesn't prevent interaction with the background content.
                            </DialogDescription>
                            <Text Size="2" Mt="4">
                                Click outside to test - the dialog won't close automatically.
                                You can still interact with the page behind this dialog.
                            </Text>
                            <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                <DialogClose AsChild="true">
                                    <Button>Close</Button>
                                </DialogClose>
                            </Flex>
                        </DialogContent>
                    </DialogRoot>
                </Card>
            </Box>

            <!-- Complex Dialog Example -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Complex Dialog Example</Heading>
                <Card>
                    <DialogRoot>
                        <DialogTrigger>
                            <Button Size="ButtonSize.Large">Create New Project</Button>
                        </DialogTrigger>
                        <DialogContent Size="DialogSize.Size3">
                            <DialogTitle>Create New Project</DialogTitle>
                            <DialogDescription>
                                Add a new project to your workspace. Fill in the details below.
                            </DialogDescription>
                            
                            <Separator My="4" />
                            
                            <Flex Direction="FlexDirection.Column" Gap="4">
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Project Name *</Text>
                                    <TextFieldRoot 
                                        Size="TextFieldSize.Size2" 
                                        Placeholder="Enter project name" />
                                </Box>
                                
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Description</Text>
                                    <TextAreaField 
                                        Size="TextAreaSize.Size2"
                                        Placeholder="Enter project description"
                                        Style="min-height: 100px;" />
                                </Box>
                                
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Project Type</Text>
                                    <SelectRoot DefaultValue="@("web")">
                                        <SelectTrigger TValue="string" Placeholder="Select a project type" />
                                        <SelectContent TValue="string">
                                            <SelectItem TValue="string" Value="@("web")">Web Application</SelectItem>
                                            <SelectItem TValue="string" Value="@("mobile")">Mobile App</SelectItem>
                                            <SelectItem TValue="string" Value="@("desktop")">Desktop Application</SelectItem>
                                            <SelectItem TValue="string" Value="@("api")">API Service</SelectItem>
                                        </SelectContent>
                                    </SelectRoot>
                                </Box>
                                
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="2">Features</Text>
                                    <Flex Direction="FlexDirection.Column" Gap="2">
                                        <Flex Align="FlexAlign.Center" Gap="2">
                                            <Checkbox DefaultChecked="CheckboxState.Checked" />
                                            <Text Size="2">Include Git repository</Text>
                                        </Flex>
                                        <Flex Align="FlexAlign.Center" Gap="2">
                                            <Checkbox DefaultChecked="CheckboxState.Checked" />
                                            <Text Size="2">Set up CI/CD pipeline</Text>
                                        </Flex>
                                        <Flex Align="FlexAlign.Center" Gap="2">
                                            <Checkbox DefaultChecked="CheckboxState.Unchecked" />
                                            <Text Size="2">Add sample data</Text>
                                        </Flex>
                                    </Flex>
                                </Box>
                            </Flex>
                            
                            <Separator My="4" />
                            
                            <Flex Gap="3" Justify="FlexJustify.End">
                                <DialogClose AsChild="true">
                                    <Button Variant="ButtonVariant.Ghost">Cancel</Button>
                                </DialogClose>
                                <Button>Create Project</Button>
                            </Flex>
                        </DialogContent>
                    </DialogRoot>
                </Card>
            </Box>

            <!-- Confirmation Dialog -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Confirmation Dialog</Heading>
                <Card>
                    <DialogRoot>
                        <DialogTrigger>
                            <Button Color="red" Variant="ButtonVariant.Soft">Delete Account</Button>
                        </DialogTrigger>
                        <DialogContent Size="DialogSize.Size2">
                            <DialogTitle>Are you absolutely sure?</DialogTitle>
                            <DialogDescription>
                                This action cannot be undone. This will permanently delete your
                                account and remove your data from our servers.
                            </DialogDescription>
                            
                            <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                <DialogClose AsChild="true">
                                    <Button Variant="ButtonVariant.Ghost">Cancel</Button>
                                </DialogClose>
                                <Button Color="red">Yes, delete account</Button>
                            </Flex>
                        </DialogContent>
                    </DialogRoot>
                </Card>
            </Box>

            <!-- Login Dialog -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Login Dialog</Heading>
                <Card>
                    <DialogRoot>
                        <DialogTrigger>
                            <Button Variant="ButtonVariant.Outline">Sign In</Button>
                        </DialogTrigger>
                        <DialogContent Size="DialogSize.Size2">
                            <DialogTitle>Welcome Back</DialogTitle>
                            <DialogDescription>
                                Sign in to your account to continue
                            </DialogDescription>
                            
                            <Flex Direction="FlexDirection.Column" Gap="3" Mt="4">
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Email</Text>
                                    <TextFieldRoot 
                                        Size="TextFieldSize.Size2" 
                                        Type="email"
                                        Placeholder="Enter your email" />
                                </Box>
                                
                                <Box>
                                    <Text Size="2" Weight="TextWeight.Medium" Mb="1">Password</Text>
                                    <TextFieldRoot 
                                        Size="TextFieldSize.Size2" 
                                        Type="password"
                                        Placeholder="Enter your password" />
                                </Box>
                                
                                <Flex Align="FlexAlign.Center" Justify="FlexJustify.Between">
                                    <Flex Align="FlexAlign.Center" Gap="2">
                                        <Checkbox />
                                        <Text Size="2">Remember me</Text>
                                    </Flex>
                                    <Link Size="2">Forgot password?</Link>
                                </Flex>
                            </Flex>
                            
                            <Flex Direction="FlexDirection.Column" Gap="2" Mt="4">
                                <Button Size="ButtonSize.Large" Style="width: 100%;">Sign In</Button>
                                <Text Size="2" Align="TextAlign.Center" Color="gray" My="2">or</Text>
                                <Button Variant="ButtonVariant.Outline" Style="width: 100%;">
                                    Sign in with Google
                                </Button>
                            </Flex>
                            
                            <Text Size="2" Align="TextAlign.Center" Mt="4">
                                Don't have an account? <Link Size="2">Sign up</Link>
                            </Text>
                        </DialogContent>
                    </DialogRoot>
                </Card>
            </Box>

            <!-- Interactive Example -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Interactive Example</Heading>
                <Card>
                    <Flex Direction="FlexDirection.Column" Gap="4">
                        <Grid Columns="2" Gap="3">
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Mb="2">Size</Text>
                                <SelectRoot @bind-Value="_selectedSize">
                                    <SelectTrigger TValue="string">
                                        <Text>@_selectedSize</Text>
                                    </SelectTrigger>
                                    <SelectContent TValue="string">
                                        @foreach (var size in Enum.GetValues<DialogSize>())
                                        {
                                            <SelectItem TValue="string" Value="@size.ToString()">@size</SelectItem>
                                        }
                                    </SelectContent>
                                </SelectRoot>
                            </Box>
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Mb="2">Modal</Text>
                                <Flex Gap="2" Align="FlexAlign.Center">
                                    <Switch @bind-Checked="_isModal" />
                                    <Text Size="2">@(_isModal ? "Modal" : "Non-modal")</Text>
                                </Flex>
                            </Box>
                        </Grid>
                        
                        <Separator />
                        
                        <DialogRoot Modal="@_isModal">
                            <DialogTrigger>
                                <Button>Open Custom Dialog</Button>
                            </DialogTrigger>
                            <DialogContent Size="@GetDialogSize()">
                                <DialogTitle>Custom Dialog</DialogTitle>
                                <DialogDescription>
                                    This dialog uses your selected settings.
                                </DialogDescription>
                                <Box Mt="4" P="3" Style="background: var(--gray-a2); border-radius: var(--radius-2);">
                                    <Text Size="2">
                                        Size: @_selectedSize<br />
                                        Modal: @_isModal
                                    </Text>
                                </Box>
                                <Flex Gap="3" Mt="5" Justify="FlexJustify.End">
                                    <DialogClose AsChild="true">
                                        <Button>Close</Button>
                                    </DialogClose>
                                </Flex>
                            </DialogContent>
                        </DialogRoot>
                    </Flex>
                </Card>
            </Box>
        </Flex>
    </Section>
</Container>

@code {
    private bool _isDialogOpen = false;
    private string _selectedSize = "Size2";
    private bool _isModal = true;
    
    private DialogSize GetDialogSize() => Enum.Parse<DialogSize>(_selectedSize);
}