{
  "name": "shadbz-blazorapp",
  "version": "1.0.0",
  "description": "Blazor app with Radix UI CSS",
  "scripts": {
    "build:css": "postcss Styles/index.css -o wwwroot/radix/index.css",
    "build:css:watch": "postcss Styles/index.css -o wwwroot/radix/index.css --watch",
    "dev": "npm run build:css:watch"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.33",
    "postcss-cli": "^11.0.0",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-custom-media": "^10.0.2",
    "postcss-discard-empty": "^7.0.0",
    "postcss-import": "^16.0.0",
    "postcss-nesting": "^14.0.0"
  }
}