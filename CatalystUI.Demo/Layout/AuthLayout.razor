@inherits LayoutComponentBase

<div class="relative flex min-h-full shrink-0 justify-center md:px-12 lg:px-0">
    <div class="relative z-10 flex flex-1 flex-col bg-white px-4 py-10 shadow-2xl dark:bg-zinc-900 sm:justify-center md:flex-none md:px-28">
        <main class="mx-auto w-full max-w-md sm:px-4 md:w-96 md:max-w-sm md:px-0">
            @Body
        </main>
    </div>
    <div class="hidden sm:contents lg:relative lg:block lg:flex-1">
        <img class="absolute inset-0 h-full w-full object-cover" src="/auth-background.jpg" alt="" />
    </div>
</div>