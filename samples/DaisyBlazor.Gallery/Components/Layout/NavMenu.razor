@* daisyUI sidebar menu listing the showcase categories. *@

<aside class="min-h-full w-72 bg-base-100 border-r border-base-300 flex flex-col">
    <div class="p-4 border-b border-base-300">
        <a href="" class="flex items-center gap-2 text-xl font-bold font-heading">
            <span class="text-2xl">🌼</span> DaisyBlazor
        </a>
        <p class="text-xs opacity-60 mt-1">Tailwind&nbsp;v4 + daisyUI&nbsp;v5 for Blazor</p>
    </div>

    <ul class="menu w-full p-3 gap-0.5 flex-1">
        <li>
            <NavLink href="" Match="NavLinkMatch.All" class="flex items-center gap-3">
                <Icon Name="@Icons.Material.Filled.Home" /> Home
            </NavLink>
        </li>
        <li class="menu-title">Components</li>
        @foreach ((string href, string icon, string label) in _categories)
        {
            <li>
                <NavLink href="@href" class="flex items-center gap-3">
                    <Icon Name="@icon" /> @label
                </NavLink>
            </li>
        }
    </ul>

    <div class="p-3 border-t border-base-300 text-xs opacity-60">
        <a class="link link-hover" href="https://github.com/phmatray/daisyblazor" target="_blank" rel="noopener">
            github.com/phmatray/daisyblazor
        </a>
    </div>
</aside>

@code {
    private readonly (string Href, string Icon, string Label)[] _categories =
    [
        ("actions",      Icons.Material.Filled.Dashboard,     "Actions"),
        ("data-display", Icons.Material.Filled.TableChart,    "Data display"),
        ("navigation",   Icons.Material.Filled.Navigation,    "Navigation"),
        ("feedback",     Icons.Material.Filled.Notifications, "Feedback"),
        ("data-input",   Icons.Material.Filled.Search,        "Data input"),
        ("layout",       Icons.Material.Filled.Dashboard,     "Layout"),
        ("mockup",       Icons.Material.Filled.Dashboard,     "Mockup"),
        ("charts",       Icons.Material.Filled.Dashboard,     "Charts"),
    ];
}
