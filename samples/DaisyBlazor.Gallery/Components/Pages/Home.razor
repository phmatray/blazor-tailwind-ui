@page "/"

<PageTitle>DaisyBlazor — Tailwind + daisyUI for Blazor</PageTitle>

<div class="hero bg-base-100 rounded-box border border-base-300 mb-8">
    <div class="hero-content text-center py-12">
        <div class="max-w-2xl">
            <div class="text-6xl mb-4">🌼</div>
            <h1 class="text-4xl font-bold font-heading">DaisyBlazor</h1>
            <p class="py-4 opacity-80">
                A Tailwind&nbsp;CSS&nbsp;v4 + daisyUI&nbsp;v5 component kit for Blazor.
                60+ daisyUI-native components, a MudBlazor-compatible API, theming, dialogs,
                snackbars, dependency-free charts, and a shippable CSS preset.
            </p>
            <div class="flex flex-wrap gap-3 justify-center">
                <a class="btn btn-primary" href="actions">Browse components</a>
                <a class="btn btn-outline" href="https://github.com/phmatray/daisyblazor" target="_blank" rel="noopener">GitHub</a>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach ((string href, string title, string desc) in _cards)
    {
        <a href="@href" class="card bg-base-100 border border-base-300 hover:border-primary transition-colors">
            <div class="card-body">
                <h2 class="card-title">@title</h2>
                <p class="text-sm opacity-70">@desc</p>
            </div>
        </a>
    }
</div>

<div class="stats stats-vertical sm:stats-horizontal shadow mt-8 w-full">
    <div class="stat">
        <div class="stat-title">daisyUI components</div>
        <div class="stat-value text-primary">61</div>
        <div class="stat-desc">mapped to Blazor</div>
    </div>
    <div class="stat">
        <div class="stat-title">Built-in themes</div>
        <div class="stat-value text-secondary">35</div>
        <div class="stat-desc">+ your own</div>
    </div>
    <div class="stat">
        <div class="stat-title">Runtime deps</div>
        <div class="stat-value text-accent">0</div>
        <div class="stat-desc">core + charts</div>
    </div>
</div>

@code {
    private readonly (string Href, string Title, string Desc)[] _cards =
    [
        ("actions",      "Actions",      "Button, Dropdown, Modal, Swap, FAB, Theme controller."),
        ("data-display", "Data display", "Card, Table, Stat, Timeline, Carousel, Chat, Diff, List."),
        ("navigation",   "Navigation",   "Tabs, Steps, Navbar, Menu, Breadcrumbs, Dock, Pagination."),
        ("feedback",     "Feedback",     "Alert, Loading, Progress, Radial, Toast, Tooltip, Skeleton."),
        ("data-input",   "Data input",   "Inputs, Select, Checkbox, Toggle, Range, Rating, File, Validator."),
        ("layout",       "Layout",       "Hero, Drawer, Footer, Divider, Join, Mask, Indicator, Stack."),
        ("mockup",       "Mockup",       "Browser, Window, Phone, and Code frames."),
        ("charts",       "Charts",       "Dependency-free SVG line, bar, pie, donut, area, sparkline."),
    ];
}
