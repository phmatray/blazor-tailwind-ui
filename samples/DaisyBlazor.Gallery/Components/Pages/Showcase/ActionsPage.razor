@page "/actions"
@rendermode InteractiveServer
@inject IDialogService DialogService

<PageTitle>Actions · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Actions</h1>
<p class="opacity-70 mb-6">Interactive controls: buttons, icon buttons, dropdowns, menus, swaps, FAB, theme controller, and dialogs.</p>

@* ── Button: colors ──────────────────────────────────────────────────────── *@
<Showcase Title="Button — Colors" Tag="<Button>" Description="Semantic color tokens mapped to daisyUI btn-* variants.">
    <Button Color="Color.Default">Default</Button>
    <Button Color="Color.Primary">Primary</Button>
    <Button Color="Color.Secondary">Secondary</Button>
    <Button Color="Color.Tertiary">Accent</Button>
    <Button Color="Color.Info">Info</Button>
    <Button Color="Color.Success">Success</Button>
    <Button Color="Color.Warning">Warning</Button>
    <Button Color="Color.Error">Error</Button>
    <Button Color="Color.Dark">Neutral</Button>
</Showcase>

@* ── Button: variants ────────────────────────────────────────────────────── *@
<Showcase Title="Button — Variants" Tag="<Button>" Description="Text (ghost), Filled, and Outlined variants for the Primary color.">
    <Button Color="Color.Primary" Variant="Variant.Text">Text / Ghost</Button>
    <Button Color="Color.Primary" Variant="Variant.Filled">Filled</Button>
    <Button Color="Color.Primary" Variant="Variant.Outlined">Outlined</Button>
</Showcase>

@* ── Button: sizes ───────────────────────────────────────────────────────── *@
<Showcase Title="Button — Sizes" Tag="<Button>" Description="Small, Medium (default), and Large.">
    <Button Color="Color.Primary" Size="Size.Small">Small</Button>
    <Button Color="Color.Primary" Size="Size.Medium">Medium</Button>
    <Button Color="Color.Primary" Size="Size.Large">Large</Button>
</Showcase>

@* ── Button: loading + disabled ─────────────────────────────────────────── *@
<Showcase Title="Button — States" Tag="<Button>" Description="Loading spinner and disabled states.">
    <Button Color="Color.Primary" Loading="true">Loading…</Button>
    <Button Color="Color.Secondary" Disabled="true">Disabled</Button>
    <Button Color="Color.Success" Loading="_saving" OnClick="SimulateSaveAsync">
        @(_saving ? "Saving…" : "Save")
    </Button>
</Showcase>

@* ── Button: icons ───────────────────────────────────────────────────────── *@
<Showcase Title="Button — Icons" Tag="<Button>" Description="StartIcon and EndIcon render Material Symbols glyphs inside the button.">
    <Button Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download">Download</Button>
    <Button Color="Color.Secondary" EndIcon="@Icons.Material.Filled.ArrowForward">Next</Button>
    <Button Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Variant="Variant.Outlined">Confirm</Button>
    <Button Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">Delete</Button>
</Showcase>

@* ── IconButton ──────────────────────────────────────────────────────────── *@
<Showcase Title="IconButton" Tag="<IconButton>" Description="Circular ghost button wrapping a single icon. Supports sizes and colors.">
    <IconButton Icon="@Icons.Material.Filled.Settings" Title="Settings" />
    <IconButton Icon="@Icons.Material.Filled.Notifications" Title="Notifications" />
    <IconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small" Title="Search" />
    <IconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Large" Title="Refresh" />
    <IconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Title="Delete" />
    <IconButton Icon="@Icons.Material.Filled.Edit" Disabled="true" Title="Edit (disabled)" />
    <span class="text-sm opacity-60 ml-2">Clicks: @_iconClickCount</span>
    <IconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Title="Increment" OnClick="@(() => _iconClickCount++)" />
</Showcase>

@* ── Dropdown ────────────────────────────────────────────────────────────── *@
<Showcase Title="Dropdown" Tag="<Dropdown>" Description="CSS-only details/summary dropdown with an Activator slot and arbitrary ChildContent panel.">
    <Dropdown>
        <Activator>
            <Button Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowDropDown">Open Menu</Button>
        </Activator>
        <ChildContent>
            <ul class="menu w-48">
                <li><a>Profile</a></li>
                <li><a>Settings</a></li>
                <li class="menu-disabled"><a>Billing (locked)</a></li>
                <li><hr class="my-1 border-base-300" /></li>
                <li><a class="text-error">Sign out</a></li>
            </ul>
        </ChildContent>
    </Dropdown>

    <Dropdown Placement="DropdownPlacement.End">
        <Activator>
            <Button Color="Color.Secondary" EndIcon="@Icons.Material.Filled.ArrowDropDown">Placement: End</Button>
        </Activator>
        <ChildContent>
            <ul class="menu w-40">
                <li><a>Action A</a></li>
                <li><a>Action B</a></li>
            </ul>
        </ChildContent>
    </Dropdown>
</Showcase>

@* ── Menu + MenuItem ─────────────────────────────────────────────────────── *@
<Showcase Title="Menu + MenuItem" Tag="<Menu> / <MenuItem>" Description="Blazor-managed open state with a transparent backdrop for outside-click dismiss. Supports icons, disabled items, and custom activators.">
    <Menu Label="File">
        <ChildContent>
            <MenuItem Icon="@Icons.Material.Filled.Download">Export</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Print">Print</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Delete" Disabled="true">Delete (locked)</MenuItem>
        </ChildContent>
    </Menu>

    <Menu Icon="@Icons.Material.Filled.Settings">
        <ChildContent>
            <MenuItem Icon="@Icons.Material.Filled.Person">Account</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Notifications">Notifications</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Logout">Sign out</MenuItem>
        </ChildContent>
    </Menu>

    <Menu AnchorOrigin="Origin.BottomRight">
        <ActivatorContent Context="activator">
            <Button Color="Color.Tertiary" OnClick="@activator.ToggleAsync" EndIcon="@Icons.Material.Filled.ArrowDropDown">Custom Activator</Button>
        </ActivatorContent>
        <ChildContent>
            <MenuItem>Option 1</MenuItem>
            <MenuItem>Option 2</MenuItem>
            <MenuItem OnClick="@OnMenuItemClicked">Notify me (@_menuClickCount)</MenuItem>
        </ChildContent>
    </Menu>
</Showcase>

@* ── Swap ────────────────────────────────────────────────────────────────── *@
<Showcase Title="Swap" Tag="<Swap>" Description="Animated CSS toggle with Rotate and Flip animations. Bind Active / ActiveChanged for two-way state.">
    <div class="flex flex-wrap gap-6 items-center">
        @* rotate animation — icon pair *@
        <div class="flex flex-col items-center gap-1">
            <Swap Animation="SwapAnimation.Rotate" Active="_swapRotate" ActiveChanged="@(v => _swapRotate = v)">
                <On><Icon Name="@Icons.Material.Filled.DarkMode" Size="Size.Large" /></On>
                <Off><Icon Name="@Icons.Material.Filled.LightMode" Size="Size.Large" /></Off>
            </Swap>
            <span class="text-xs opacity-60">Rotate · @(_swapRotate ? "Dark" : "Light")</span>
        </div>

        @* flip animation — emoji pair *@
        <div class="flex flex-col items-center gap-1">
            <Swap Animation="SwapAnimation.Flip" Active="_swapFlip" ActiveChanged="@(v => _swapFlip = v)">
                <On><span class="text-3xl">😎</span></On>
                <Off><span class="text-3xl">🙂</span></Off>
            </Swap>
            <span class="text-xs opacity-60">Flip · @(_swapFlip ? "Cool" : "Normal")</span>
        </div>

        @* no animation — text toggle *@
        <div class="flex flex-col items-center gap-1">
            <Swap Animation="SwapAnimation.None" Active="_swapText" ActiveChanged="@(v => _swapText = v)" Class="text-lg font-bold">
                <On><span class="text-success">ON</span></On>
                <Off><span class="text-error">OFF</span></Off>
            </Swap>
            <span class="text-xs opacity-60">No animation</span>
        </div>
    </div>
</Showcase>

@* ── Fab ─────────────────────────────────────────────────────────────────── *@
<Showcase Title="FAB — Speed Dial" Tag="<Fab> / <FabAction>" Description="Floating action button with speed-dial actions. Focus or click the trigger to expand." BodyClass="block space-y-8">
    <div class="flex flex-wrap gap-16 items-end pb-4">
        @* vertical stack *@
        <div class="flex flex-col items-center gap-2">
            <p class="text-sm opacity-60 mb-1">Vertical stack</p>
            <Fab Color="Color.Primary">
                <FabAction Icon="@Icons.Material.Filled.Email" Tooltip="Email" Color="Color.Secondary" />
                <FabAction Icon="@Icons.Material.Filled.Download" Tooltip="Download" Color="Color.Info" />
                <FabAction Icon="@Icons.Material.Filled.Print" Tooltip="Print" />
            </Fab>
        </div>

        @* flower layout *@
        <div class="flex flex-col items-center gap-2">
            <p class="text-sm opacity-60 mb-1">Flower layout</p>
            <Fab Color="Color.Secondary" Flower="true">
                <FabAction Icon="@Icons.Material.Filled.ContentCopy" Tooltip="Copy" TooltipPosition="top" />
                <FabAction Icon="@Icons.Material.Filled.Edit" Tooltip="Edit" TooltipPosition="right" />
                <FabAction Icon="@Icons.Material.Filled.Delete" Tooltip="Delete" Color="Color.Error" TooltipPosition="bottom" />
            </Fab>
        </div>

        @* custom icon *@
        <div class="flex flex-col items-center gap-2">
            <p class="text-sm opacity-60 mb-1">Custom icon</p>
            <Fab Icon="@Icons.Material.Filled.Public" Color="Color.Success">
                <FabAction Icon="@Icons.Material.Filled.Email" Tooltip="Email" />
                <FabAction Icon="@Icons.Material.Filled.People" Tooltip="Share with team" />
            </Fab>
        </div>
    </div>
</Showcase>

@* ── ThemeController ─────────────────────────────────────────────────────── *@
<Showcase Title="ThemeController" Tag="<ThemeController>" Description="CSS-only theme switching via the daisyUI theme-controller input. No JavaScript needed." BodyClass="block space-y-6">
    <div>
        <p class="text-sm font-semibold mb-2">Checkbox toggle (light ↔ dark)</p>
        <ThemeController Value="dark" Checked="_darkTheme" CheckedChanged="@(v => _darkTheme = v)">
            <Swap Animation="SwapAnimation.Rotate" Active="_darkTheme">
                <On><Icon Name="@Icons.Material.Filled.DarkMode" /></On>
                <Off><Icon Name="@Icons.Material.Filled.LightMode" /></Off>
            </Swap>
        </ThemeController>
        <span class="text-xs opacity-60 ml-2">Active theme: @(_darkTheme ? "dark" : "default")</span>
    </div>

    <div>
        <p class="text-sm font-semibold mb-2">Radio group — pick a theme</p>
        <div class="flex flex-wrap gap-3">
            @foreach (string theme in _radioThemes)
            {
                <ThemeController Type="ThemeControllerType.Radio"
                                 Value="@theme"
                                 Name="theme-radio-demo"
                                 Checked="@(_activeRadioTheme == theme)"
                                 CheckedChanged="@(v => { if (v) _activeRadioTheme = theme; })">
                    <span class="btn btn-sm btn-outline capitalize">@theme</span>
                </ThemeController>
            }
        </div>
        <p class="text-xs opacity-60 mt-2">Selected: @_activeRadioTheme</p>
    </div>
</Showcase>

@* ── Modal / IDialogService ──────────────────────────────────────────────── *@
<Showcase Title="Modal — IDialogService" Tag="IDialogService" Description="ShowMessageBoxAsync opens a built-in confirm dialog rendered by the mounted DialogProvider." BodyClass="flex flex-row flex-wrap items-center gap-4">
    <Button Color="Color.Primary" OnClick="ShowInfoDialogAsync">Info message</Button>
    <Button Color="Color.Warning" OnClick="ShowConfirmDialogAsync">Confirm dialog</Button>
    <Button Color="Color.Error" OnClick="ShowDestructiveDialogAsync">Destructive confirm</Button>

    @if (!string.IsNullOrEmpty(_dialogResult))
    {
        <div class="badge badge-outline text-sm px-3 py-2">Last result: @_dialogResult</div>
    }
</Showcase>

@code
{
    // Button: simulated async save
    private bool _saving;

    private async Task SimulateSaveAsync()
    {
        _saving = true;
        await Task.Delay(1500);
        _saving = false;
    }

    // IconButton click counter
    private int _iconClickCount;

    // Menu click counter
    private int _menuClickCount;

    private void OnMenuItemClicked()
    {
        _menuClickCount++;
    }

    // Swap states
    private bool _swapRotate;
    private bool _swapFlip;
    private bool _swapText;

    // ThemeController — checkbox
    private bool _darkTheme;

    // ThemeController — radio group
    private readonly string[] _radioThemes = ["light", "dark", "cupcake", "synthwave", "aqua"];
    private string _activeRadioTheme = "light";

    // Dialog results
    private string _dialogResult = string.Empty;

    private async Task ShowInfoDialogAsync()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            title: "Information",
            message: "DaisyBlazor dialogs are rendered by IDialogService + DialogProvider — no JS required.",
            yesText: "Got it");

        _dialogResult = result == true ? "acknowledged" : "dismissed";
    }

    private async Task ShowConfirmDialogAsync()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            title: "Confirm action",
            message: "Are you sure you want to proceed with this operation?",
            yesText: "Yes, proceed",
            noText: "No",
            cancelText: "Cancel");

        _dialogResult = result switch
        {
            true  => "confirmed (Yes)",
            false => "declined (No)",
            null  => "canceled"
        };
    }

    private async Task ShowDestructiveDialogAsync()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            title: "Delete item?",
            message: "This action cannot be undone. All associated data will be permanently removed.",
            yesText: "Delete",
            noText: "Keep it",
            cancelText: "Cancel");

        _dialogResult = result switch
        {
            true  => "deleted",
            false => "kept",
            null  => "canceled"
        };
    }
}
