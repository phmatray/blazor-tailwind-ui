@namespace CatalystUI.Components
@inherits CatalystComponentBase
@typeparam TValue

<div class="relative" @ref="comboboxElement">
    <span data-slot="control" class="@GetControlClasses()">
        <input @ref="inputElement"
               @bind="Query"
               @bind:event="oninput"
               @onfocus="HandleFocus"
               @onblur="HandleBlur"
               type="text"
               role="combobox"
               aria-expanded="@IsOpen.ToString().ToLower()"
               aria-controls="combobox-options"
               aria-label="@AriaLabel"
               placeholder="@Placeholder"
               disabled="@Disabled"
               class="@GetInputClasses()"
               @attributes="GetAttributes()" />
        <button type="button" 
                @onclick="ToggleDropdown" 
                class="group absolute inset-y-0 right-0 flex items-center px-2"
                disabled="@Disabled">
            <svg class="size-5 stroke-zinc-500 group-disabled:stroke-zinc-600 group-hover:stroke-zinc-700 sm:size-4 dark:stroke-zinc-400 dark:group-hover:stroke-zinc-300 forced-colors:stroke-[CanvasText]"
                 viewBox="0 0 16 16"
                 aria-hidden="true"
                 fill="none">
                <path d="M5.75 10.75L8 13L10.25 10.75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M10.25 5.25L8 3L5.75 5.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </button>
    </span>
    
    @if (IsOpen && FilteredOptions.Any())
    {
        <div id="combobox-options" 
             class="@GetOptionsClasses()"
             @onmousedown:preventDefault="true">
            @foreach (var option in FilteredOptions)
            {
                <CascadingValue Value="this">
                    @OptionTemplate(option)
                </CascadingValue>
            }
        </div>
    }
</div>