## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# Node modules and npm
node_modules/
npm-debug.log*

# Tailwind CSS output
wwwroot/css/app.css
wwwroot/css/app.css.map

# Other files
*.log
*.cache
*.dll
*.pdb
*.tmp
