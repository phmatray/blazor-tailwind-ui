@namespace Radixor.Components.Overlays
@inherits Radixor.Components.Base.SpacingComponentBase
@implements IDisposable

@if (ContextMenuRoot?.IsOpen == true)
{
    @if (ContextMenuRoot.Modal)
    {
        <div class="rt-ContextMenuOverlay" @onclick="HandleOverlayClick"></div>
    }
    <div class="@ContentCssClass" @attributes="GetAllAttributes()" @onkeydown="HandleKeyDown" style="@GetPositionStyle()" tabindex="-1">
        @ChildContent
    </div>
}