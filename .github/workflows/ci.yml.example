name: CI/CD Pipeline

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]

jobs:
  build-and-test:
    name: Build and Test
    runs-on: ${{ matrix.os }}

    strategy:
      matrix:
        os: [ubuntu-latest, macos-latest, windows-latest]
        dotnet-version: ['10.0.x']

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup .NET
      uses: actions/setup-dotnet@v4
      with:
        dotnet-version: ${{ matrix.dotnet-version }}

    - name: Setup Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'

    - name: Restore dependencies
      run: dotnet restore

    - name: Build project
      run: dotnet build --configuration Release --no-restore

    - name: Run unit tests
      run: dotnet test --configuration Release --no-build --verbosity normal --filter Category=Unit

    - name: Run integration tests
      run: dotnet test --configuration Release --no-build --verbosity normal --filter Category=Integration

    - name: Run contract tests (with npm available)
      run: dotnet test --configuration Release --no-build --verbosity normal --filter Category=Contract
      continue-on-error: true  # Contract tests may be skipped on CI

    - name: Upload test results
      if: always()
      uses: actions/upload-artifact@v4
      with:
        name: test-results-${{ matrix.os }}
        path: '**/TestResults/*.trx'

    - name: Build Release Binary
      if: matrix.os == 'ubuntu-latest'
      run: dotnet publish TailwindToolbox/TailwindToolbox.csproj -c Release -o ./publish

    - name: Upload Release Binary
      if: matrix.os == 'ubuntu-latest'
      uses: actions/upload-artifact@v4
      with:
        name: tailwind-blazor-linux
        path: ./publish/tailwind-blazor

  code-quality:
    name: Code Quality Checks
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup .NET
      uses: actions/setup-dotnet@v4
      with:
        dotnet-version: '10.0.x'

    - name: Restore dependencies
      run: dotnet restore

    - name: Check nullable reference types compliance
      run: |
        echo "Checking nullable reference types are enabled..."
        grep -q '<Nullable>enable</Nullable>' TailwindToolbox/TailwindToolbox.csproj
        grep -q '<Nullable>enable</Nullable>' TailwindToolbox.Tests/TailwindToolbox.Tests.csproj

    - name: Check warnings as errors
      run: |
        echo "Checking TreatWarningsAsErrors is enabled..."
        grep -q '<TreatWarningsAsErrors>true</TreatWarningsAsErrors>' TailwindToolbox/TailwindToolbox.csproj

    - name: Build with warnings as errors
      run: dotnet build --configuration Release /warnaserror

    - name: Run code coverage
      run: dotnet test --configuration Release --collect:"XPlat Code Coverage" --results-directory ./coverage

    - name: Upload coverage to Codecov
      uses: codecov/codecov-action@v4
      with:
        directory: ./coverage
        flags: unittests
        name: codecov-umbrella

  validate-example-project:
    name: Validate on Example Blazor Project
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup .NET
      uses: actions/setup-dotnet@v4
      with:
        dotnet-version: '10.0.x'

    - name: Setup Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20.x'

    - name: Build Tailwind Blazor CLI
      run: dotnet build -c Release TailwindToolbox/TailwindToolbox.csproj

    - name: Create sample Blazor project
      run: |
        dotnet new blazor -n TestBlazorApp -o ./test-project
        cd ./test-project

    - name: Run setup command (dry-run)
      run: |
        dotnet run --project ../TailwindToolbox/TailwindToolbox.csproj -- setup --project-dir ./test-project --dry-run

    - name: Run setup command (actual)
      run: |
        dotnet run --project ../TailwindToolbox/TailwindToolbox.csproj -- setup --project-dir ./test-project

    - name: Run check command
      run: |
        dotnet run --project ../TailwindToolbox/TailwindToolbox.csproj -- check --project-dir ./test-project --fail-on-warning

    - name: Build Blazor project with Tailwind
      run: |
        cd ./test-project
        dotnet build

    - name: Verify Tailwind CSS output exists
      run: |
        test -f ./test-project/wwwroot/css/app.css || (echo "Tailwind CSS output not found!" && exit 1)

  release:
    name: Create Release
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    needs: [build-and-test, code-quality, validate-example-project]
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup .NET
      uses: actions/setup-dotnet@v4
      with:
        dotnet-version: '10.0.x'

    - name: Extract version from .csproj
      id: get_version
      run: |
        VERSION=$(grep -oP '<Version>\K[^<]+' TailwindToolbox/TailwindToolbox.csproj)
        echo "version=$VERSION" >> $GITHUB_OUTPUT

    - name: Build Release Binaries
      run: |
        dotnet publish TailwindToolbox/TailwindToolbox.csproj -c Release -r linux-x64 --self-contained -o ./publish/linux-x64
        dotnet publish TailwindToolbox/TailwindToolbox.csproj -c Release -r osx-x64 --self-contained -o ./publish/osx-x64
        dotnet publish TailwindToolbox/TailwindToolbox.csproj -c Release -r win-x64 --self-contained -o ./publish/win-x64

    - name: Create GitHub Release
      uses: softprops/action-gh-release@v1
      with:
        tag_name: v${{ steps.get_version.outputs.version }}
        name: Release v${{ steps.get_version.outputs.version }}
        draft: false
        prerelease: false
        files: |
          ./publish/linux-x64/tailwind-blazor
          ./publish/osx-x64/tailwind-blazor
          ./publish/win-x64/tailwind-blazor.exe
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
