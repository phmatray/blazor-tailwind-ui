{
  "name": "daisyblazor-app",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind CSS v4 + daisyUI v5 build for a DaisyBlazor app",
  "scripts": {
    "build:css": "tailwindcss -i ./Styles/main.css -o ./wwwroot/css/app.css --minify",
    "watch:css": "tailwindcss -i ./Styles/main.css -o ./wwwroot/css/app.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "daisyui": "5.5.20",
    "tailwindcss": "^4.1.0"
  }
}
