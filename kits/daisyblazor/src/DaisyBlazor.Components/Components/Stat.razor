@namespace DaisyBlazor

@* Single stat cell. daisyUI .stat containing optional stat-figure, stat-title,
   stat-value, stat-desc, and an optional actions area below the description. *@

<div class="stat" style="@Style" @attributes="UserAttributes">
    @if (Figure is not null)
    {
        <div class="stat-figure">
            @Figure
        </div>
    }
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="stat-title">@Title</div>
    }
    @if (!string.IsNullOrEmpty(Value))
    {
        <div class="stat-value">@Value</div>
    }
    @if (!string.IsNullOrEmpty(Desc))
    {
        <div class="@_descCls">@Desc</div>
    }
    @if (Actions is not null)
    {
        <div class="stat-actions">
            @Actions
        </div>
    }
</div>

@code {
    /// <summary>Stat label shown above the value (e.g. "Total Flights").</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Primary numeric or text value displayed prominently.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Supplementary description shown below the value.</summary>
    [Parameter] public string? Desc { get; set; }

    /// <summary>Semantic color applied to the stat-desc text (maps to text-{token}).</summary>
    [Parameter] public Color? DescColor { get; set; }

    /// <summary>Optional figure content (e.g. an icon or avatar) rendered in stat-figure.</summary>
    [Parameter] public RenderFragment? Figure { get; set; }

    /// <summary>Optional action content (e.g. buttons or links) rendered below the description.</summary>
    [Parameter] public RenderFragment? Actions { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string _descCls
    {
        get
        {
            string? token = DescColor.HasValue ? CssClass.ColorToken(DescColor.Value) : null;
            return CssClass.Merge(
                "stat-desc",
                token is not null ? $"text-{token}" : null);
        }
    }
}
