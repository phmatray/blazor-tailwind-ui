@namespace DaisyBlazor

@* MudExpansionPanel replacement. daisyUI .collapse .collapse-arrow via <details> for
   server-friendly, no-JS expand/collapse. *@

<details class="@_cls" name="@_name" open="@IsExpanded" style="@Style" @attributes="UserAttributes">
    <summary class="collapse-title flex items-center gap-2 font-medium">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <Icon Name="@Icon" Size="Size.Small" />
        }
        @if (TitleContent is not null)
        {
            @TitleContent
        }
        else if (!string.IsNullOrEmpty(Text))
        {
            <span>@Text</span>
        }
    </summary>
    <div class="collapse-content">
        @ChildContent
    </div>
</details>

@code {
    [CascadingParameter] private ExpansionPanels? Parent { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Dense { get; set; }

    /// <summary>Whether the panel is expanded. Both MudBlazor names are supported.</summary>
    [Parameter] public bool IsExpanded { get; set; }

    [Parameter]
    public bool Expanded
    {
        get => IsExpanded;
        set => IsExpanded = value;
    }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    // Single-open accordion: share the parent group name. Multi-open: omit name.
    private string? _name => Parent is { MultiExpansion: false } p ? p.GroupName : null;

    private string _cls => CssClass.Merge(
        "collapse collapse-arrow bg-base-100 border border-base-300 rounded-box",
        Class);
}
