@namespace DaisyBlazor
@typeparam T

@* MudToggleItem<T> replacement. One button of a ToggleGroup segmented control. *@

<button type="button" class="@_cls" disabled="@(Disabled || (Parent?.Disabled ?? false))"
        @onclick="OnClickHandler" style="@Style" @attributes="UserAttributes">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <Icon Name="@Icon" Size="Size.Small" />
    }
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else if (!string.IsNullOrEmpty(Text))
    {
        <span>@Text</span>
    }
</button>

@code {
    [CascadingParameter] private ToggleGroup<T>? Parent { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public T? Value { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private bool _selected => Parent?.IsSelected(Value) ?? false;

    private string _cls => CssClass.Merge(
        "join-item btn",
        Parent?.SizeClass,
        _selected ? Parent?.ActiveColor : "btn-ghost",
        Class);

    private async Task OnClickHandler()
    {
        if (Parent is not null)
        {
            await Parent.SelectAsync(Value);
        }
    }
}
