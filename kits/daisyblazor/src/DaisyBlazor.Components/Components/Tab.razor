@namespace DaisyBlazor

@* Individual tab within a <Tabs> container. Registers with the cascaded Tabs parent
   on init and unregisters on dispose. The tab button and content panel are rendered
   by the parent; this component only holds metadata and ChildContent. *@

@implements IDisposable

@code {
    [CascadingParameter] private Tabs? Parent { get; set; }

    /// <summary>Text label shown in the tab button.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>When true the tab button is rendered as disabled and is not selectable.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Content displayed in the tab panel when this tab is active.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    protected override void OnInitialized()
    {
        Parent?.RegisterTab(this);
    }

    public void Dispose()
    {
        Parent?.UnregisterTab(this);
    }
}
