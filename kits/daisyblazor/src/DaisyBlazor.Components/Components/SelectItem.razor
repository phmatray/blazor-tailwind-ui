@namespace DaisyBlazor
@typeparam T
@implements IDisposable

@* MudSelectItem<T> replacement. Registers itself with the parent Select; renders nothing
   directly (the parent Select emits the <option> using this item's ChildContent + Value). *@

@code {
    [Parameter] public T? Value { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    [CascadingParameter] private Select<T>? Parent { get; set; }

    protected override void OnInitialized()
    {
        Parent?.RegisterItem(this);
    }

    public void Dispose()
    {
        Parent?.UnregisterItem(this);
    }
}
