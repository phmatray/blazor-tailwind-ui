@namespace DaisyBlazor

@* MudProgressCircular replacement. daisyUI .loading .loading-spinner with size + color.
   daisyUI spinners are always indeterminate; Value is accepted for compatibility. *@

<span class="@_cls" style="@Style" role="status" aria-label="@AriaLabel" @attributes="UserAttributes"></span>

@code {
    [Parameter] public bool Indeterminate { get; set; } = true;
    [Parameter] public double Value { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; } = 100;
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public string AriaLabel { get; set; } = "loading";

    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string _colorClass => CssClass.TextColor(Color) ?? string.Empty;

    private string _cls => CssClass.Merge(
        "loading",
        "loading-spinner",
        CssClass.LoadingSize(Size),
        _colorClass,
        Class);
}
