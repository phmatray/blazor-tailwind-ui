@namespace DaisyBlazor

@* MudTimeline replacement. daisyUI vertical .timeline. *@

<ul class="@_cls" style="@Style" @attributes="UserAttributes">
    @ChildContent
</ul>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public TimelinePosition TimelinePosition { get; set; } = TimelinePosition.Alternate;
    [Parameter] public bool Reverse { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    private string _cls => CssClass.Merge(
        "timeline timeline-vertical timeline-compact",
        Class);
}
