@namespace DaisyBlazor.Data

@* MudBlazor StatusChip replacement. A filled chip for status indicators. *@

<Chip T="string"
      Color="@Color"
      Size="@Size"
      Variant="Variant.Filled"
      Icon="@Icon"
      Class="@Class"
      Style="@Style"
      @attributes="UserAttributes">
    @Label
</Chip>
