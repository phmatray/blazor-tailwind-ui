@page "/charts"

<PageTitle>Charts · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Charts</h1>
<p class="opacity-70 mb-6">Dependency-free SVG charts — no JS libraries, theme-aware colors, zero runtime dependencies.</p>

@* ── LineChart ───────────────────────────────────────────────────────────── *@
<Showcase Title="LineChart"
          Tag="<LineChart>"
          Description="Multi-series line chart with optional grid, points, and legend."
          BodyClass="block space-y-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <p class="text-xs opacity-60 mb-2">Two series · smooth · grid + points</p>
            <LineChart Series="_lineSeries"
                       Labels="_monthLabels"
                       Smooth="true"
                       ShowGrid="true"
                       ShowPoints="true"
                       ShowLegend="true"
                       Title="Monthly Revenue vs. Expenses (k€)" />
        </div>
        <div>
            <p class="text-xs opacity-60 mb-2">Single series · straight lines</p>
            <LineChart Series="_singleSeries"
                       Labels="_weekLabels"
                       Smooth="false"
                       ShowGrid="true"
                       ShowPoints="true"
                       ShowLegend="false"
                       Title="Weekly Active Users" />
        </div>
    </div>
</Showcase>

@* ── AreaChart ───────────────────────────────────────────────────────────── *@
<Showcase Title="AreaChart"
          Tag="<AreaChart>"
          Description="Same as LineChart but with the area under each line filled. Smooth curves recommended."
          BodyClass="block space-y-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <p class="text-xs opacity-60 mb-2">Two series · smooth · area fill</p>
            <AreaChart Series="_areaSeries"
                       Labels="_quarterLabels"
                       Smooth="true"
                       ShowGrid="true"
                       ShowPoints="false"
                       ShowLegend="true"
                       Title="Quarterly Bookings vs. Cancellations" />
        </div>
        <div>
            <p class="text-xs opacity-60 mb-2">Single series · area fill</p>
            <AreaChart Series="_tempSeries"
                       Labels="_monthLabels"
                       Smooth="true"
                       ShowGrid="true"
                       ShowPoints="true"
                       ShowLegend="false"
                       Title="Average Temperature (°C)" />
        </div>
    </div>
</Showcase>

@* ── BarChart ────────────────────────────────────────────────────────────── *@
<Showcase Title="BarChart"
          Tag="<BarChart>"
          Description="Vertical or horizontal bars from flat ChartDataPoint lists or grouped ChartSeries."
          BodyClass="block space-y-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <p class="text-xs opacity-60 mb-2">Flat data · vertical bars</p>
            <BarChart Data="_departmentData"
                      ShowGrid="true"
                      Title="Headcount by Department" />
        </div>
        <div>
            <p class="text-xs opacity-60 mb-2">Flat data · horizontal bars</p>
            <BarChart Data="_departmentData"
                      Horizontal="true"
                      ShowGrid="true"
                      Title="Headcount by Department (horizontal)" />
        </div>
    </div>
    <div class="grid grid-cols-1 gap-6 mt-2">
        <div>
            <p class="text-xs opacity-60 mb-2">Grouped series · two series per category</p>
            <BarChart Series="_salesSeries"
                      Labels="_quarterLabels"
                      ShowGrid="true"
                      ShowLegend="true"
                      Title="Sales vs. Target by Quarter" />
        </div>
    </div>
</Showcase>

@* ── PieChart ────────────────────────────────────────────────────────────── *@
<Showcase Title="PieChart"
          Tag="<PieChart>"
          Description="Circular slices computed from ChartDataPoint values; legend shows percentages."
          BodyClass="block space-y-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <p class="text-xs opacity-60 mb-2">Five slices · with legend</p>
            <PieChart Data="_trafficData"
                      ShowLegend="true"
                      Title="Traffic Sources" />
        </div>
        <div>
            <p class="text-xs opacity-60 mb-2">Four slices · no legend</p>
            <PieChart Data="_budgetData"
                      ShowLegend="false"
                      Title="Budget Allocation" />
        </div>
    </div>
</Showcase>

@* ── DonutChart ──────────────────────────────────────────────────────────── *@
<Showcase Title="DonutChart"
          Tag="<DonutChart>"
          Description="Donut (ring) chart with configurable hole size and optional center label."
          BodyClass="block space-y-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
            <p class="text-xs opacity-60 mb-2">Center label · default hole size (0.6)</p>
            <DonutChart Data="_statusData"
                        ShowLegend="true"
                        CenterLabel="85%"
                        Title="Ticket Resolution Rate" />
        </div>
        <div>
            <p class="text-xs opacity-60 mb-2">Thin ring · InnerRadiusRatio 0.8</p>
            <DonutChart Data="_osData"
                        ShowLegend="true"
                        InnerRadiusRatio="0.8"
                        Title="Platform Distribution" />
        </div>
    </div>
</Showcase>

@* ── Sparkline ───────────────────────────────────────────────────────────── *@
<Showcase Title="Sparkline"
          Tag="<Sparkline>"
          Description="Tiny inline trend line for table cells and KPI tiles — no axes, no labels."
          BodyClass="block space-y-4">
    <div class="overflow-x-auto">
        <table class="table table-sm w-full">
            <thead>
                <tr>
                    <th>Metric</th>
                    <th>Current</th>
                    <th>Trend (30 d)</th>
                    <th>Area fill</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Page views</td>
                    <td class="font-medium">24 819</td>
                    <td><Sparkline Data="_sparkViews" Width="6rem" Height="2rem" ShowEndDot="true" /></td>
                    <td><Sparkline Data="_sparkViews" Width="6rem" Height="2rem" Area="true" ShowEndDot="false" /></td>
                </tr>
                <tr>
                    <td>Sign-ups</td>
                    <td class="font-medium">1 204</td>
                    <td><Sparkline Data="_sparkSignups" Width="6rem" Height="2rem" Color="var(--color-success)" ShowEndDot="true" /></td>
                    <td><Sparkline Data="_sparkSignups" Width="6rem" Height="2rem" Color="var(--color-success)" Area="true" ShowEndDot="false" /></td>
                </tr>
                <tr>
                    <td>Error rate</td>
                    <td class="font-medium text-error">0.4%</td>
                    <td><Sparkline Data="_sparkErrors" Width="6rem" Height="2rem" Color="var(--color-error)" ShowEndDot="true" /></td>
                    <td><Sparkline Data="_sparkErrors" Width="6rem" Height="2rem" Color="var(--color-error)" Area="true" ShowEndDot="false" /></td>
                </tr>
                <tr>
                    <td>Latency p99</td>
                    <td class="font-medium">142 ms</td>
                    <td><Sparkline Data="_sparkLatency" Width="6rem" Height="2rem" Color="var(--color-warning)" ShowEndDot="true" /></td>
                    <td><Sparkline Data="_sparkLatency" Width="6rem" Height="2rem" Color="var(--color-warning)" Area="true" ShowEndDot="false" /></td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="flex flex-wrap gap-6 mt-4">
        <div class="flex items-center gap-2">
            <span class="text-sm opacity-70">Revenue</span>
            <Sparkline Data="_sparkRevenue" Width="8rem" Height="2.5rem" Area="true" ShowEndDot="true" />
            <span class="text-sm font-semibold">€ 128k</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-sm opacity-70">NPS</span>
            <Sparkline Data="_sparkNps" Width="8rem" Height="2.5rem" Color="var(--color-secondary)" ShowEndDot="true" />
            <span class="text-sm font-semibold">72</span>
        </div>
    </div>
</Showcase>

