@page "/mockup"

<PageTitle>Mockup · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Mockup</h1>
<p class="opacity-70 mb-6">Device and window chrome components for showcasing UI inside realistic frames.</p>

<Showcase Title="MockupBrowser" Tag="<MockupBrowser>" Description="Renders a browser chrome with an address bar and arbitrary content in the display area." BodyClass="block space-y-4">
    <MockupBrowser Url="https://daisyblazor.dev">
        <div class="flex flex-col items-center gap-2 py-4">
            <p class="text-lg font-semibold">Welcome to DaisyBlazor</p>
            <p class="text-sm opacity-70">Build beautiful Blazor UIs with daisyUI components.</p>
            <button class="btn btn-primary btn-sm">Get Started</button>
        </div>
    </MockupBrowser>

    <MockupBrowser Url="https://example.com/dashboard" BorderColor="Color.Primary">
        <div class="grid grid-cols-3 gap-3 py-4 w-full max-w-md">
            <div class="stat bg-base-200 rounded-box p-3 text-center">
                <div class="stat-value text-xl">128</div>
                <div class="stat-desc">Flights</div>
            </div>
            <div class="stat bg-base-200 rounded-box p-3 text-center">
                <div class="stat-value text-xl">42</div>
                <div class="stat-desc">Gates</div>
            </div>
            <div class="stat bg-base-200 rounded-box p-3 text-center">
                <div class="stat-value text-xl">99%</div>
                <div class="stat-desc">Uptime</div>
            </div>
        </div>
    </MockupBrowser>
</Showcase>

<Showcase Title="MockupWindow" Tag="<MockupWindow>" Description="Renders a desktop window chrome with a title bar." BodyClass="block space-y-4">
    <MockupWindow Title="My Application">
        <div class="flex flex-col items-center gap-3 py-4">
            <p class="font-medium">Hello from a desktop window!</p>
            <div class="flex gap-2">
                <button class="btn btn-sm btn-outline">Cancel</button>
                <button class="btn btn-sm btn-primary">Save</button>
            </div>
        </div>
    </MockupWindow>

    <MockupWindow Title="Error — File not found" BorderColor="Color.Error">
        <div class="flex items-center gap-3 py-4 text-error">
            <span class="text-2xl">⚠</span>
            <p>The requested file could not be located.</p>
        </div>
    </MockupWindow>
</Showcase>

<Showcase Title="MockupPhone" Tag="<MockupPhone>" Description="Renders a phone device chrome with a camera notch and a display area." BodyClass="flex flex-row flex-wrap gap-8 items-start">
    <MockupPhone>
        <div class="flex flex-col items-center justify-center h-full gap-4 bg-base-200 p-6 text-center">
            <p class="text-2xl font-bold">DaisyBlazor</p>
            <p class="text-sm opacity-70">Mobile-ready components</p>
            <button class="btn btn-primary btn-sm w-full">Open App</button>
        </div>
    </MockupPhone>

    <MockupPhone>
        <div class="flex flex-col gap-2 bg-base-100 p-4 h-full">
            <p class="font-semibold text-sm border-b border-base-300 pb-2 mb-1">Notifications</p>
            <div class="flex items-start gap-2">
                <span class="badge badge-primary badge-sm mt-0.5">New</span>
                <p class="text-xs">Flight BX402 gate changed to B12.</p>
            </div>
            <div class="flex items-start gap-2">
                <span class="badge badge-ghost badge-sm mt-0.5">Info</span>
                <p class="text-xs">Check-in for LH123 opens in 2 h.</p>
            </div>
        </div>
    </MockupPhone>
</Showcase>

<Showcase Title="MockupCode" Tag="<MockupCode>" Description="Renders a terminal / code block. Use Lines for simple line lists or ChildContent for custom prefix rows." BodyClass="block space-y-4">
    <MockupCode Lines="@_installLines" Prefix="$" />

    <MockupCode>
        <pre data-prefix="1"><code>@("@page \"/hello\"")</code></pre>
        <pre data-prefix="2"><code></code></pre>
        <pre data-prefix="3"><code>&lt;h1&gt;Hello, world!&lt;/h1&gt;</code></pre>
        <pre data-prefix="4"><code></code></pre>
        <pre data-prefix="5" class="text-success"><code>@("@code { /* ready */ }")</code></pre>
    </MockupCode>
</Showcase>

@code
{
    private readonly IReadOnlyList<string> _installLines = new[]
    {
        "dotnet new blazorserver -n MyApp",
        "cd MyApp",
        "dotnet add package DaisyBlazor",
        "dotnet run"
    };
}
