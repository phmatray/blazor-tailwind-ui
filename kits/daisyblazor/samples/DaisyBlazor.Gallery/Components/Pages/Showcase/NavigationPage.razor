@page "/navigation"
@rendermode InteractiveServer

<PageTitle>Navigation · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Navigation</h1>
<p class="opacity-70 mb-6">Tabs, steps, navbars, breadcrumbs, dock, pagination, links, and menus for building navigable UIs.</p>

@* ── Tabs ────────────────────────────────────────────────────────────────── *@
<Showcase Title="Tabs + Tab" Tag="<Tabs> / <Tab>" Description="Bind ActiveIndex for two-way control. Variants: Box (default), Border, Lift." BodyClass="block space-y-6">
    <div class="space-y-1">
        <p class="text-sm font-medium opacity-60">Box (default) — active index: @_boxIndex</p>
        <Tabs @bind-ActiveIndex="_boxIndex" Variant="TabsVariant.Box">
            <Tab Title="Dashboard">
                <div class="p-4 flex items-center gap-3">
                    <Icon Name="@Icons.Material.Filled.Dashboard" />
                    <span>Dashboard content — overview charts and KPIs live here.</span>
                </div>
            </Tab>
            <Tab Title="Flights">
                <div class="p-4 flex items-center gap-3">
                    <Icon Name="@Icons.Material.Filled.FlightTakeoff" />
                    <span>Flight list with real-time status updates.</span>
                </div>
            </Tab>
            <Tab Title="Reports">
                <div class="p-4 flex items-center gap-3">
                    <Icon Name="@Icons.Material.Filled.Assessment" />
                    <span>Export and review operational reports.</span>
                </div>
            </Tab>
            <Tab Title="Disabled" Disabled="true">
                <span>This panel is never visible.</span>
            </Tab>
        </Tabs>
    </div>

    <div class="space-y-1">
        <p class="text-sm font-medium opacity-60">Border variant — active index: @_borderIndex</p>
        <Tabs @bind-ActiveIndex="_borderIndex" Variant="TabsVariant.Border">
            <Tab Title="Profile">
                <div class="p-4">User profile settings and preferences.</div>
            </Tab>
            <Tab Title="Security">
                <div class="p-4">Password, 2FA, and active session management.</div>
            </Tab>
            <Tab Title="Notifications">
                <div class="p-4">Configure alert channels and delivery rules.</div>
            </Tab>
        </Tabs>
    </div>

    <div class="space-y-1">
        <p class="text-sm font-medium opacity-60">Lift variant — active index: @_liftIndex</p>
        <Tabs @bind-ActiveIndex="_liftIndex" Variant="TabsVariant.Lift">
            <Tab Title="Overview">
                <div class="p-4">Project overview and status summary.</div>
            </Tab>
            <Tab Title="Activity">
                <div class="p-4">Recent activity feed and audit log.</div>
            </Tab>
        </Tabs>
    </div>
</Showcase>

@* ── Steps ───────────────────────────────────────────────────────────────── *@
<Showcase Title="Steps + Step" Tag="<Steps> / <Step>" Description="Horizontal workflow tracker with completed, active, and upcoming states." BodyClass="block space-y-6">
    <div>
        <p class="text-sm font-medium opacity-60 mb-3">Onboarding wizard (step @_currentStep of 4)</p>
        <Steps>
            <Step Completed="@(_currentStep > 1)" Active="@(_currentStep == 1)">Sign up</Step>
            <Step Completed="@(_currentStep > 2)" Active="@(_currentStep == 2)">Verify email</Step>
            <Step Completed="@(_currentStep > 3)" Active="@(_currentStep == 3)">Set preferences</Step>
            <Step Completed="@(_currentStep > 4)" Active="@(_currentStep == 4)">Done</Step>
        </Steps>
        <div class="flex gap-2 mt-4">
            <button class="btn btn-sm btn-outline" disabled="@(_currentStep <= 1)" @onclick="PrevStep">Back</button>
            <button class="btn btn-sm btn-primary" disabled="@(_currentStep >= 4)" @onclick="NextStep">Next</button>
        </div>
    </div>

    <div>
        <p class="text-sm font-medium opacity-60 mb-3">Custom markers &amp; colors</p>
        <Steps>
            <Step Color="Color.Success" DataContent="✓">Deployed</Step>
            <Step Color="Color.Warning" DataContent="!">Review pending</Step>
            <Step Color="Color.Error" DataContent="✕">Tests failed</Step>
            <Step>Queued</Step>
        </Steps>
    </div>

    <div>
        <p class="text-sm font-medium opacity-60 mb-3">Vertical layout</p>
        <Steps Vertical="true" Class="max-h-56">
            <Step Completed="true">Plan</Step>
            <Step Active="true">Build</Step>
            <Step>Test</Step>
            <Step>Ship</Step>
        </Steps>
    </div>
</Showcase>

@* ── Navbar ──────────────────────────────────────────────────────────────── *@
<Showcase Title="Navbar" Tag="<Navbar>" Description="Start / Center / End regions with optional color, border, and shadow." BodyClass="block space-y-4">
    <Navbar Shadow="true">
        <Start>
            <a class="btn btn-ghost text-xl">DaisyBlazor</a>
        </Start>
        <Center>
            <ul class="menu menu-horizontal px-1">
                <li><a>Docs</a></li>
                <li><a>Components</a></li>
                <li><a>Gallery</a></li>
            </ul>
        </Center>
        <End>
            <button class="btn btn-primary btn-sm">Get Started</button>
        </End>
    </Navbar>

    <Navbar Color="Color.Primary" Bordered="true">
        <Start>
            <Icon Name="@Icons.Material.Filled.AirplaneTicket" Class="text-primary-content" />
            <span class="ml-2 font-semibold text-primary-content">HorizonHub</span>
        </Start>
        <End>
            <button class="btn btn-ghost btn-sm text-primary-content">
                <Icon Name="@Icons.Material.Filled.Person" />
                Profile
            </button>
        </End>
    </Navbar>
</Showcase>

@* ── Breadcrumbs ─────────────────────────────────────────────────────────── *@
<Showcase Title="Breadcrumbs" Tag="<Breadcrumbs>" Description="Pass a List&lt;BreadcrumbItem&gt;; items with a null Href render as plain text." BodyClass="block space-y-4">
    <Breadcrumbs Items="@_simpleCrumbs" />
    <Breadcrumbs Items="@_iconCrumbs" />
    <Breadcrumbs Items="@_disabledCrumbs" />
</Showcase>

@* ── Dock ────────────────────────────────────────────────────────────────── *@
<Showcase Title="Dock + DockItem" Tag="<Dock> / <DockItem>" Description="Fixed bottom navigation bar. Rendered statically here for preview; use inside a full-page layout for the real fixed effect." BodyClass="block space-y-4">
    <div class="relative bg-base-200 rounded-box h-24 overflow-hidden">
        <p class="p-4 text-sm opacity-60">Page content area</p>
        <div class="dock">
            <DockItem Icon="@Icons.Material.Filled.Home" Label="Home" Active="@(_dockActive == 0)" OnClick="@(() => _dockActive = 0)" />
            <DockItem Icon="@Icons.Material.Filled.Search" Label="Search" Active="@(_dockActive == 1)" OnClick="@(() => _dockActive = 1)" />
            <DockItem Icon="@Icons.Material.Filled.Notifications" Label="Alerts" Active="@(_dockActive == 2)" OnClick="@(() => _dockActive = 2)" />
            <DockItem Icon="@Icons.Material.Filled.Person" Label="Profile" Active="@(_dockActive == 3)" OnClick="@(() => _dockActive = 3)" />
        </div>
    </div>
    <p class="text-sm opacity-60">Active item: <strong>@_dockLabels[_dockActive]</strong></p>

    <div class="relative bg-base-200 rounded-box h-20 overflow-hidden">
        <p class="p-3 text-sm opacity-60">Small dock (dock-sm)</p>
        <Dock Size="DockSize.Sm">
            <DockItem Icon="@Icons.Material.Filled.Home" Label="Home" Active="true" />
            <DockItem Icon="@Icons.Material.Filled.FlightTakeoff" Label="Flights" />
            <DockItem Icon="@Icons.Material.Filled.Settings" Label="Settings" />
        </Dock>
    </div>
</Showcase>

@* ── Pagination ──────────────────────────────────────────────────────────── *@
<Showcase Title="Pagination" Tag="<Pagination>" Description="1-based Selected; bind for two-way control. ShowFirstButton / ShowLastButton add jump-to-end buttons." BodyClass="block space-y-6">
    <div class="space-y-2">
        <p class="text-sm opacity-60">Default — page <strong>@_page</strong> of 10</p>
        <Pagination Count="10" @bind-Selected="_page" ShowFirstButton="true" ShowLastButton="true" />
    </div>

    <div class="space-y-2">
        <p class="text-sm opacity-60">Primary color — page <strong>@_colorPage</strong> of 20</p>
        <Pagination Count="20" @bind-Selected="_colorPage" Color="Color.Primary" />
    </div>

    <div class="space-y-2">
        <p class="text-sm opacity-60">Disabled</p>
        <Pagination Count="5" Selected="3" Disabled="true" />
    </div>
</Showcase>

@* ── TextLink ────────────────────────────────────────────────────────────── *@
<Showcase Title="TextLink" Tag="<TextLink>" Description="Semantic &lt;a&gt; element with color and underline variants.">
    <TextLink Href="#">Default (primary, hover underline)</TextLink>
    <TextLink Href="#" Color="Color.Secondary">Secondary</TextLink>
    <TextLink Href="#" Color="Color.Tertiary">Accent</TextLink>
    <TextLink Href="#" Color="Color.Success">Success</TextLink>
    <TextLink Href="#" Color="Color.Error">Error</TextLink>
    <TextLink Href="#" Underline="Underline.Always" Color="Color.Info">Always underlined</TextLink>
    <TextLink Href="#" Underline="Underline.None" Color="Color.Warning">No underline</TextLink>
</Showcase>

@* ── Menu ────────────────────────────────────────────────────────────────── *@
<Showcase Title="Menu" Tag="<Menu> / <MenuItem>" Description="Dropdown menus with a button or icon activator. Open state is managed server-side — no JS required." BodyClass="flex flex-row flex-wrap items-start gap-6 min-h-48">
    <div>
        <p class="text-xs opacity-60 mb-1">Button label activator</p>
        <Menu Label="Actions">
            <MenuItem Icon="@Icons.Material.Filled.Edit" OnClick="@(() => _menuLog = "Edit clicked")">Edit</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => _menuLog = "Duplicate clicked")">Duplicate</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Save" OnClick="@(() => _menuLog = "Archive clicked")">Archive</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@(() => _menuLog = "Delete clicked")" Class="text-error">Delete</MenuItem>
        </Menu>
    </div>

    <div>
        <p class="text-xs opacity-60 mb-1">Icon activator</p>
        <Menu Icon="@Icons.Material.Filled.Menu">
            <MenuItem Icon="@Icons.Material.Filled.OpenInNew" OnClick="@(() => _menuLog = "Share clicked")">Share</MenuItem>
            <MenuItem Icon="@Icons.Material.Filled.Download" OnClick="@(() => _menuLog = "Download clicked")">Download</MenuItem>
            <MenuItem Disabled="true" Icon="@Icons.Material.Filled.Lock">Restricted</MenuItem>
        </Menu>
    </div>

    <div>
        <p class="text-xs opacity-60 mb-1">Custom activator</p>
        <Menu>
            <ActivatorContent>
                <button class="btn btn-outline btn-accent btn-sm gap-1" @onclick="context.ToggleAsync">
                    <Icon Name="@Icons.Material.Filled.Add" Size="Size.Small" />
                    New item
                </button>
            </ActivatorContent>
            <ChildContent>
                <MenuItem Icon="@Icons.Material.Filled.Notes" OnClick="@(() => _menuLog = "Document clicked")">Document</MenuItem>
                <MenuItem Icon="@Icons.Material.Filled.MenuBook" OnClick="@(() => _menuLog = "Folder clicked")">Folder</MenuItem>
            </ChildContent>
        </Menu>
    </div>

    @if (!string.IsNullOrEmpty(_menuLog))
    {
        <div class="w-full">
            <span class="badge badge-neutral text-xs">Last action: @_menuLog</span>
        </div>
    }
</Showcase>

@code
{
    // Tabs
    private int _boxIndex;
    private int _borderIndex;
    private int _liftIndex;

    // Steps
    private int _currentStep = 1;

    private void NextStep()
    {
        if (_currentStep < 4)
        {
            _currentStep++;
        }
    }

    private void PrevStep()
    {
        if (_currentStep > 1)
        {
            _currentStep--;
        }
    }

    // Breadcrumbs
    private readonly List<BreadcrumbItem> _simpleCrumbs = new()
    {
        new BreadcrumbItem("Home", "/"),
        new BreadcrumbItem("Components", "/components"),
        new BreadcrumbItem("Navigation", null, Disabled: true)
    };

    private readonly List<BreadcrumbItem> _iconCrumbs = new()
    {
        new BreadcrumbItem("Home", "/", Icon: Icons.Material.Filled.Home),
        new BreadcrumbItem("Flights", "/flights", Icon: Icons.Material.Filled.FlightTakeoff),
        new BreadcrumbItem("BX 402", null, Disabled: true, Icon: Icons.Material.Filled.AirplaneTicket)
    };

    private readonly List<BreadcrumbItem> _disabledCrumbs = new()
    {
        new BreadcrumbItem("Home", "/"),
        new BreadcrumbItem("Settings", null, Disabled: true),
        new BreadcrumbItem("Security", null, Disabled: true)
    };

    // Dock
    private int _dockActive;
    private readonly string[] _dockLabels = { "Home", "Search", "Alerts", "Profile" };

    // Pagination
    private int _page = 1;
    private int _colorPage = 5;

    // Menu
    private string _menuLog = string.Empty;
}
