@page "/layout"
@rendermode InteractiveServer

<PageTitle>Layout · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Layout</h1>
<p class="opacity-70 mb-6">Structural primitives: containers, grids, dividers, heroes, footers, and overlay utilities.</p>

@* ─── Container ──────────────────────────────────────────────────────────── *@
<Showcase Title="Container" Tag="<Container>" Description="Centered, max-width-constrained content wrapper with optional gutters." BodyClass="block space-y-3">
    <Container MaxWidth="MaxWidth.Small" Class="bg-base-200 rounded p-3 text-center text-sm">
        MaxWidth.Small — narrow content column
    </Container>
    <Container MaxWidth="MaxWidth.Medium" Class="bg-base-200 rounded p-3 text-center text-sm">
        MaxWidth.Medium — article-width column
    </Container>
    <Container MaxWidth="MaxWidth.Large" Class="bg-base-200 rounded p-3 text-center text-sm">
        MaxWidth.Large (default) — standard page column
    </Container>
    <Container MaxWidth="MaxWidth.ExtraLarge" Class="bg-base-200 rounded p-3 text-center text-sm">
        MaxWidth.ExtraLarge — wide dashboard column
    </Container>
</Showcase>

@* ─── Grid + Item ────────────────────────────────────────────────────────── *@
<Showcase Title="Grid + Item" Tag="<Grid> / <Item>" Description="12-column CSS grid with responsive breakpoint spans." BodyClass="block">
    <Grid Spacing="4">
        <Item xs="12" md="6" lg="4">
            <div class="bg-primary/10 border border-primary/30 rounded p-3 text-sm text-center">
                xs=12 md=6 lg=4
            </div>
        </Item>
        <Item xs="12" md="6" lg="4">
            <div class="bg-secondary/10 border border-secondary/30 rounded p-3 text-sm text-center">
                xs=12 md=6 lg=4
            </div>
        </Item>
        <Item xs="12" md="12" lg="4">
            <div class="bg-accent/10 border border-accent/30 rounded p-3 text-sm text-center">
                xs=12 md=12 lg=4
            </div>
        </Item>
        <Item xs="6">
            <div class="bg-base-200 rounded p-3 text-sm text-center">xs=6 (half)</div>
        </Item>
        <Item xs="4">
            <div class="bg-base-200 rounded p-3 text-sm text-center">xs=4 (third)</div>
        </Item>
        <Item xs="2">
            <div class="bg-base-200 rounded p-3 text-sm text-center">xs=2</div>
        </Item>
        <Item xs="12">
            <div class="bg-base-300 rounded p-3 text-sm text-center">xs=12 (full width)</div>
        </Item>
    </Grid>
</Showcase>

@* ─── Divider ────────────────────────────────────────────────────────────── *@
<Showcase Title="Divider" Tag="<Divider>" Description="Horizontal and vertical separators, optionally labelled." BodyClass="block space-y-2">
    <p class="text-sm opacity-70">Horizontal (default)</p>
    <Divider />

    <p class="text-sm opacity-70 mt-2">Horizontal with label</p>
    <Divider>OR</Divider>

    <p class="text-sm opacity-70 mt-2">Vertical (Vertical=true) — inside a flex row</p>
    <div class="flex items-center h-10 gap-0">
        <span class="text-sm px-4">Left</span>
        <Divider Vertical="true" />
        <span class="text-sm px-4">Right</span>
    </div>
</Showcase>

@* ─── Hero ───────────────────────────────────────────────────────────────── *@
<Showcase Title="Hero" Tag="<Hero>" Description="Full-bleed hero section with centred content. MinHeight controls the height." BodyClass="block space-y-4">
    <Hero MinHeight="min-h-48" Class="bg-gradient-to-r from-primary to-secondary rounded-box text-primary-content">
        <div class="text-center">
            <h2 class="text-2xl font-bold mb-2">Welcome aboard</h2>
            <p class="opacity-80 mb-4 text-sm">Build stunning Blazor apps with daisyUI components.</p>
            <button class="btn btn-sm btn-outline text-primary-content border-primary-content hover:bg-primary-content hover:text-primary">
                Get Started
            </button>
        </div>
    </Hero>

    <Hero MinHeight="min-h-32" Class="bg-base-200 rounded-box">
        <div class="max-w-md text-center">
            <p class="text-sm opacity-70">Plain variant — no image, no overlay, just centred content inside <code>.hero</code>.</p>
        </div>
    </Hero>
</Showcase>

@* ─── Footer + FooterTitle ───────────────────────────────────────────────── *@
<Showcase Title="Footer + FooterTitle" Tag="<Footer> / <FooterTitle>" Description="Site footer with labelled navigation sections." BodyClass="block">
    <Footer Color="Color.Dark" Padding="p-8" Class="rounded-box text-neutral-content">
        <nav>
            <FooterTitle>Product</FooterTitle>
            <a class="link link-hover text-sm">Features</a>
            <a class="link link-hover text-sm">Pricing</a>
            <a class="link link-hover text-sm">Changelog</a>
        </nav>
        <nav>
            <FooterTitle>Resources</FooterTitle>
            <a class="link link-hover text-sm">Documentation</a>
            <a class="link link-hover text-sm">Tutorials</a>
            <a class="link link-hover text-sm">GitHub</a>
        </nav>
        <nav>
            <FooterTitle>Company</FooterTitle>
            <a class="link link-hover text-sm">About</a>
            <a class="link link-hover text-sm">Blog</a>
            <a class="link link-hover text-sm">Contact</a>
        </nav>
    </Footer>
</Showcase>

@* ─── Indicator ──────────────────────────────────────────────────────────── *@
<Showcase Title="Indicator" Tag="<Indicator>" Description="Overlay a badge or dot over any child element. Control position with Horizontal and Vertical.">
    <Indicator>
        <Item>
            <span class="badge badge-primary badge-sm">3</span>
        </Item>
        <ChildContent>
            <button class="btn">Inbox</button>
        </ChildContent>
    </Indicator>

    <Indicator Horizontal="IndicatorHorizontal.Start" Vertical="IndicatorVertical.Middle">
        <Item>
            <span class="badge badge-error badge-xs"></span>
        </Item>
        <ChildContent>
            <button class="btn btn-outline">Notifications</button>
        </ChildContent>
    </Indicator>

    <Indicator Horizontal="IndicatorHorizontal.Center" Vertical="IndicatorVertical.Bottom">
        <Item>
            <span class="badge badge-success badge-sm">New</span>
        </Item>
        <ChildContent>
            <button class="btn btn-secondary">Updates</button>
        </ChildContent>
    </Indicator>

    <Indicator>
        <Item>
            <span class="badge badge-warning badge-sm">99+</span>
        </Item>
        <ChildContent>
            <div class="bg-base-200 rounded-box w-24 h-16 flex items-center justify-center text-xs opacity-60">
                any child
            </div>
        </ChildContent>
    </Indicator>
</Showcase>

@* ─── Mask ───────────────────────────────────────────────────────────────── *@
<Showcase Title="Mask" Tag="<Mask>" Description="Clip content into geometric shapes using the daisyUI mask-* utilities.">
    @foreach ((MaskShape shape, string label, string bg) in _masks)
    {
        <div class="flex flex-col items-center gap-1">
            <Mask Shape="@shape" Class="w-16 h-16">
                <div class="@bg w-full h-full flex items-center justify-center text-xs text-white font-semibold">
                    @label
                </div>
            </Mask>
            <span class="text-xs opacity-60">@label</span>
        </div>
    }
</Showcase>

@* ─── StackOverlay ───────────────────────────────────────────────────────── *@
<Showcase Title="StackOverlay" Tag="<StackOverlay>" Description="Layer children on top of each other (daisyUI .stack). Useful for card piles or depth effects.">
    <StackOverlay Class="w-40">
        <div class="card bg-primary text-primary-content w-full h-20 shadow rounded-box"></div>
        <div class="card bg-secondary text-secondary-content w-full h-20 shadow rounded-box"></div>
        <div class="card bg-accent text-accent-content w-full h-20 shadow rounded-box flex items-center justify-center text-sm font-semibold">
            Top card
        </div>
    </StackOverlay>

    <StackOverlay Align="StackAlign.Bottom" Class="w-40">
        <div class="card bg-base-300 w-full h-20 rounded-box"></div>
        <div class="card bg-base-200 w-full h-20 rounded-box"></div>
        <div class="card bg-base-100 border border-base-300 w-full h-20 rounded-box flex items-center justify-center text-xs opacity-70">
            stack-bottom
        </div>
    </StackOverlay>
</Showcase>

@* ─── ButtonGroup ────────────────────────────────────────────────────────── *@
<Showcase Title="ButtonGroup" Tag="<ButtonGroup>" Description="Groups adjacent buttons into a joined control (daisyUI .join).">
    <ButtonGroup>
        <Button Color="Color.Default" Variant="Variant.Outlined">Left</Button>
        <Button Color="Color.Default" Variant="Variant.Outlined">Center</Button>
        <Button Color="Color.Default" Variant="Variant.Outlined">Right</Button>
    </ButtonGroup>

    <ButtonGroup>
        <Button Color="Color.Primary" Variant="Variant.Filled">Save</Button>
        <Button Color="Color.Primary" Variant="Variant.Filled">Save &amp; Close</Button>
    </ButtonGroup>

    <ButtonGroup>
        <Button Color="Color.Error" Variant="Variant.Outlined" StartIcon="delete">Delete</Button>
        <Button Color="Color.Default" Variant="Variant.Outlined" StartIcon="archive">Archive</Button>
        <Button Color="Color.Default" Variant="Variant.Outlined" StartIcon="share">Share</Button>
    </ButtonGroup>
</Showcase>

@* ─── ToggleGroup + ToggleItem ───────────────────────────────────────────── *@
<Showcase Title="ToggleGroup + ToggleItem" Tag="<ToggleGroup<T>> / <ToggleItem<T>>" Description="Single-selection segmented control with two-way binding. Selected value is shown below each group." BodyClass="block space-y-6">
    <div>
        <p class="text-xs opacity-60 mb-2 font-mono">string — text labels</p>
        <div class="flex flex-col gap-2">
            <ToggleGroup T="string" @bind-Value="_alignment" Color="Color.Primary">
                <ToggleItem T="string" Value="@("left")"   Text="Left" />
                <ToggleItem T="string" Value="@("center")" Text="Center" />
                <ToggleItem T="string" Value="@("right")"  Text="Right" />
            </ToggleGroup>
            <p class="text-sm">Selected: <strong>@(_alignment ?? "none")</strong></p>
        </div>
    </div>

    <div>
        <p class="text-xs opacity-60 mb-2 font-mono">string — icon labels</p>
        <div class="flex flex-col gap-2">
            <ToggleGroup T="string" @bind-Value="_view" Color="Color.Secondary" Size="Size.Small">
                <ToggleItem T="string" Value="@("list")"   Icon="list" />
                <ToggleItem T="string" Value="@("grid")"   Icon="grid_view" />
                <ToggleItem T="string" Value="@("table")"  Icon="table_chart" />
            </ToggleGroup>
            <p class="text-sm">View: <strong>@(_view ?? "none")</strong></p>
        </div>
    </div>

    <div>
        <p class="text-xs opacity-60 mb-2 font-mono">int — numeric selection</p>
        <div class="flex flex-col gap-2">
            <ToggleGroup T="int" @bind-Value="_quantity" Color="Color.Tertiary">
                <ToggleItem T="int" Value="1"  Text="1×" />
                <ToggleItem T="int" Value="5"  Text="5×" />
                <ToggleItem T="int" Value="10" Text="10×" />
                <ToggleItem T="int" Value="25" Text="25×" />
            </ToggleGroup>
            <p class="text-sm">Quantity: <strong>@_quantity</strong></p>
        </div>
    </div>
</Showcase>

@* ─── Drawer (inline demo) ───────────────────────────────────────────────── *@
<Showcase Title="Drawer" Tag="<Drawer>" Description="A CSS-only slide-in panel driven by a hidden checkbox toggle. The demo below is self-contained inside a bordered box so it doesn't take over the page layout." BodyClass="block">
    <div class="border border-base-300 rounded-box overflow-hidden" style="height:220px; position:relative;">
        <Drawer Open="@_drawerOpen" OpenChanged="@(v => _drawerOpen = v)" Id="demo-drawer" Class="h-full">
            <ChildContent>
                <div class="p-4 flex flex-col gap-3 h-full">
                    <p class="text-sm font-medium">Main content area</p>
                    <p class="text-xs opacity-60">Drawer is currently <strong>@(_drawerOpen ? "open" : "closed")</strong>.</p>
                    <button class="btn btn-primary btn-sm w-fit" @onclick="@(() => _drawerOpen = !_drawerOpen)">
                        @(_drawerOpen ? "Close drawer" : "Open drawer")
                    </button>
                </div>
            </ChildContent>
            <SideContent>
                <ul class="menu bg-base-200 min-h-full w-56 p-4 gap-1">
                    <li class="menu-title text-xs">Navigation</li>
                    <li><a class="text-sm">Dashboard</a></li>
                    <li><a class="text-sm">Reports</a></li>
                    <li><a class="text-sm">Settings</a></li>
                    <li class="mt-auto">
                        <button class="btn btn-ghost btn-sm justify-start text-sm" @onclick="@(() => _drawerOpen = false)">
                            Close
                        </button>
                    </li>
                </ul>
            </SideContent>
        </Drawer>
    </div>
</Showcase>

@code
{
    private string? _alignment = "center";
    private string? _view = "list";
    private int _quantity = 5;
    private bool _drawerOpen;

    private readonly (MaskShape Shape, string Label, string Bg)[] _masks =
    [
        (MaskShape.Squircle, "Squircle", "bg-primary"),
        (MaskShape.Circle,   "Circle",   "bg-secondary"),
        (MaskShape.Hexagon,  "Hexagon",  "bg-accent"),
        (MaskShape.Star,     "Star",     "bg-success"),
        (MaskShape.Star2,    "Star2",    "bg-warning"),
        (MaskShape.Heart,    "Heart",    "bg-error"),
        (MaskShape.Diamond,  "Diamond",  "bg-info"),
        (MaskShape.Triangle, "Triangle", "bg-primary"),
        (MaskShape.Pentagon, "Pentagon", "bg-secondary"),
    ];
}
