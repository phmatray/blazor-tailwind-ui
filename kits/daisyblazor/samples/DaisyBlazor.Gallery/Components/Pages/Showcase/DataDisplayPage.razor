@page "/data-display"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Data display · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Data display</h1>
<p class="opacity-70 mb-6">Cards, tables, stats, timelines, and all the components that present information to users.</p>

@* ── Card ──────────────────────────────────────────────────────────────── *@
<Showcase Title="Card" Tag="<Card>" Description="Surface container with optional header, content, and action slots." BodyClass="flex flex-row flex-wrap gap-4 items-start">
    <Card Class="w-64">
        <CardHeader>
            <CardHeaderAvatar>
                <Avatar Color="Color.Primary">JD</Avatar>
            </CardHeaderAvatar>
            <CardHeaderContent>
                <p class="font-semibold">Jane Doe</p>
                <p class="text-xs opacity-60">Product designer</p>
            </CardHeaderContent>
        </CardHeader>
        <CardContent>
            <p class="text-sm">Building beautiful interfaces with daisyUI and Blazor.</p>
        </CardContent>
        <CardActions>
            <button class="btn btn-primary btn-sm">Follow</button>
            <button class="btn btn-ghost btn-sm">Message</button>
        </CardActions>
    </Card>

    <Card Outlined Class="w-64">
        <CardContent>
            <p class="card-title text-base">Outlined card</p>
            <p class="text-sm opacity-70">Uses a border instead of elevation shadow.</p>
        </CardContent>
        <CardActions>
            <button class="btn btn-outline btn-sm btn-secondary">Learn more</button>
        </CardActions>
    </Card>

    <Card Elevation="8" Class="w-64">
        <CardContent>
            <p class="card-title text-base">Elevated card</p>
            <p class="text-sm opacity-70">Elevation=8 produces a large drop shadow.</p>
        </CardContent>
    </Card>
</Showcase>

@* ── Avatar ────────────────────────────────────────────────────────────── *@
<Showcase Title="Avatar" Tag="<Avatar>" Description="Circular image or initials placeholder in various colors and sizes.">
    <Avatar Image="https://i.pravatar.cc/100?img=1" Alt="Alice" />
    <Avatar Color="Color.Primary">AL</Avatar>
    <Avatar Color="Color.Secondary">BX</Avatar>
    <Avatar Color="Color.Success">CS</Avatar>
    <Avatar Color="Color.Warning">DW</Avatar>
    <Avatar Color="Color.Error">EX</Avatar>
    <Avatar Color="Color.Dark">FZ</Avatar>
    <Avatar Size="Size.Small" Color="Color.Info">SM</Avatar>
    <Avatar Size="Size.Large" Color="Color.Tertiary">LG</Avatar>
</Showcase>

@* ── Badge ─────────────────────────────────────────────────────────────── *@
<Showcase Title="Badge" Tag="<Badge>" Description="Indicator overlay on child content with color, dot, and max-cap options.">
    <Badge Content="4" Color="Color.Primary">
        <button class="btn btn-ghost">Inbox</button>
    </Badge>
    <Badge Content="128" Max="99" Color="Color.Error" Bordered>
        <button class="btn btn-ghost">Notifications</button>
    </Badge>
    <Badge Dot Color="Color.Success">
        <Avatar Color="Color.Dark">AI</Avatar>
    </Badge>
    <Badge Visible="false" Content="@("hidden")">
        <button class="btn btn-ghost">No badge</button>
    </Badge>
</Showcase>

@* ── Chip ──────────────────────────────────────────────────────────────── *@
<Showcase Title="Chip" Tag="<Chip<T>>" Description="Compact label with optional icon, close button, and click handling.">
    <Chip T="string" Text="Default" />
    <Chip T="string" Text="Primary" Color="Color.Primary" />
    <Chip T="string" Text="Secondary" Color="Color.Secondary" />
    <Chip T="string" Text="Success" Color="Color.Success" />
    <Chip T="string" Text="Outlined" Color="Color.Info" Variant="Variant.Outlined" />
    <Chip T="string" Text="Soft" Color="Color.Warning" Variant="Variant.Text" />
    <Chip T="string" Text="With icon" Color="Color.Tertiary" Icon="star" />
    <Chip T="string" Text="Clickable" Color="Color.Primary" OnClick="@(() => _chipClicks++)" />
    <Chip T="string" Text="Closable" Color="Color.Error" OnClose="@(c => _chipVisible = false)" />
    @if (!_chipVisible)
    {
        <span class="text-xs opacity-60">(chip closed)</span>
    }
    @if (_chipClicks > 0)
    {
        <span class="text-xs opacity-60">Clicked @_chipClicks×</span>
    }
</Showcase>

@* ── SimpleTable ───────────────────────────────────────────────────────── *@
<Showcase Title="SimpleTable" Tag="<SimpleTable>" Description="Lightweight daisyUI table with striped, hover, dense, and bordered variants." BodyClass="block space-y-4">
    <SimpleTable Hover Striped>
        <thead>
            <tr>
                <th>Flight</th>
                <th>Route</th>
                <th>Departure</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (FlightRow row in _flights)
            {
                <tr>
                    <td class="font-mono font-semibold">@row.Number</td>
                    <td>@row.Route</td>
                    <td>@row.Departure</td>
                    <td>
                        <span class="badge @row.StatusClass badge-sm">@row.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </SimpleTable>

    <SimpleTable Dense Bordered>
        <thead>
            <tr><th>Name</th><th>Role</th><th>Dept</th></tr>
        </thead>
        <tbody>
            <tr><td>Alice Moreau</td><td>Engineer</td><td>Tech</td></tr>
            <tr><td>Bob Lefevre</td><td>Manager</td><td>Ops</td></tr>
            <tr><td>Clara Petit</td><td>Designer</td><td>UX</td></tr>
        </tbody>
    </SimpleTable>
</Showcase>

@* ── Stats / Stat ──────────────────────────────────────────────────────── *@
<Showcase Title="Stats + Stat" Tag="<Stats> / <Stat>" Description="Numeric summary widgets with figure, title, value, and description slots." BodyClass="block space-y-4">
    <Stats Shadow>
        <Stat Title="Total flights" Value="1 284" Desc="+12% this month" DescColor="Color.Success">
            <Figure>
                <Avatar Color="Color.Primary">✈</Avatar>
            </Figure>
        </Stat>
        <Stat Title="Passengers" Value="94 730" Desc="All terminals" DescColor="Color.Info">
            <Figure>
                <Avatar Color="Color.Secondary">👤</Avatar>
            </Figure>
        </Stat>
        <Stat Title="Incidents" Value="3" Desc="-2 vs last week" DescColor="Color.Error">
            <Figure>
                <Avatar Color="Color.Warning">⚠</Avatar>
            </Figure>
        </Stat>
    </Stats>

    <Stats Vertical Shadow Class="w-64">
        <Stat Title="On-time rate" Value="97.4%" Desc="Last 30 days" />
        <Stat Title="Avg delay" Value="4 min" Desc="Domestic routes" />
    </Stats>
</Showcase>

@* ── Timeline ──────────────────────────────────────────────────────────── *@
<Showcase Title="Timeline + TimelineItem" Tag="<Timeline> / <TimelineItem>" Description="Vertical event timeline with colored dots and opposite-side labels." BodyClass="block">
    <Timeline>
        <TimelineItem Color="Color.Success" Icon="check_circle">
            <ItemOpposite><span class="text-xs opacity-60">09:00</span></ItemOpposite>
            <ItemContent><p class="font-semibold text-sm">Flight BX201 departed</p><p class="text-xs opacity-70">Gate A3 — on time</p></ItemContent>
        </TimelineItem>
        <TimelineItem Color="Color.Primary" Icon="flight_land">
            <ItemOpposite><span class="text-xs opacity-60">11:30</span></ItemOpposite>
            <ItemContent><p class="font-semibold text-sm">Flight LH445 arrived</p><p class="text-xs opacity-70">Terminal 2</p></ItemContent>
        </TimelineItem>
        <TimelineItem Color="Color.Warning" Icon="warning">
            <ItemOpposite><span class="text-xs opacity-60">13:15</span></ItemOpposite>
            <ItemContent><p class="font-semibold text-sm">Gate change — SN102</p><p class="text-xs opacity-70">Moved from B4 → B9</p></ItemContent>
        </TimelineItem>
        <TimelineItem Color="Color.Error" Icon="cancel">
            <ItemOpposite><span class="text-xs opacity-60">14:00</span></ItemOpposite>
            <ItemContent><p class="font-semibold text-sm">Flight TX890 cancelled</p><p class="text-xs opacity-70">Passengers redirected</p></ItemContent>
        </TimelineItem>
        <TimelineItem Color="Color.Info" Icon="schedule">
            <ItemOpposite><span class="text-xs opacity-60">17:45</span></ItemOpposite>
            <ItemContent><p class="font-semibold text-sm">Boarding — KL312</p><p class="text-xs opacity-70">Gate C7 — 15 min delay</p></ItemContent>
        </TimelineItem>
    </Timeline>
</Showcase>

@* ── Carousel ──────────────────────────────────────────────────────────── *@
<Showcase Title="Carousel + CarouselItem" Tag="<Carousel> / <CarouselItem>" Description="Horizontal scroll carousel with fixed-width items." BodyClass="block">
    <Carousel Class="w-full max-w-lg rounded-box" Snap="CarouselSnap.Center">
        @foreach (CarouselSlide slide in _slides)
        {
            <CarouselItem Width="100%">
                <div class="flex items-center justify-center rounded-box h-40 text-white text-xl font-bold" style="background-color: @slide.Color;">
                    @slide.Label
                </div>
            </CarouselItem>
        }
    </Carousel>
</Showcase>

@* ── ChatBubble ────────────────────────────────────────────────────────── *@
<Showcase Title="ChatBubble" Tag="<ChatBubble>" Description="Chat message row with start/end placement, colors, headers, and footers." BodyClass="block space-y-1 max-w-md">
    <ChatBubble Placement="ChatPlacement.Start" Header="Support · 10:32" Footer="Delivered" Color="Color.Default">
        <ChildContent>Hello! How can I help you today?</ChildContent>
    </ChatBubble>
    <ChatBubble Placement="ChatPlacement.End" Header="You · 10:33" Color="Color.Primary">
        <ChildContent>I need help with my booking reference.</ChildContent>
    </ChatBubble>
    <ChatBubble Placement="ChatPlacement.Start" Header="Support · 10:34" Footer="Seen" Color="Color.Info">
        <ChildContent>Sure! Please share your booking ID and I'll look it up right away.</ChildContent>
    </ChatBubble>
    <ChatBubble Placement="ChatPlacement.End" Color="Color.Secondary">
        <ChildContent>It's <strong>BX-20240604-987</strong>.</ChildContent>
    </ChatBubble>
</Showcase>

@* ── Countdown ─────────────────────────────────────────────────────────── *@
<Showcase Title="Countdown" Tag="<Countdown>" Description="Animated digit display for timers and countdowns.">
    <div class="flex items-end gap-1 font-mono text-5xl font-bold">
        <Countdown Value="@_cdHours" Label="hrs" />
        <span class="pb-4 opacity-60">:</span>
        <Countdown Value="@_cdMinutes" Label="min" />
        <span class="pb-4 opacity-60">:</span>
        <Countdown Value="@_cdSeconds" Label="sec" />
    </div>
    <div class="flex gap-2 ml-4">
        <button class="btn btn-sm btn-primary" @onclick="StartCountdown">Start</button>
        <button class="btn btn-sm btn-ghost" @onclick="ResetCountdown">Reset</button>
    </div>
</Showcase>

@* ── Diff ──────────────────────────────────────────────────────────────── *@
<Showcase Title="Diff" Tag="<Diff>" Description="Side-by-side slider comparison of two content panels." BodyClass="block max-w-xl">
    <Diff AspectClass="aspect-4/3">
        <Item1>
            <div class="bg-base-200 w-full h-full flex items-center justify-center">
                <div class="text-center">
                    <p class="text-4xl font-black opacity-20">BEFORE</p>
                    <p class="text-sm opacity-50 mt-2">Old design</p>
                </div>
            </div>
        </Item1>
        <Item2>
            <div class="bg-primary text-primary-content w-full h-full flex items-center justify-center">
                <div class="text-center">
                    <p class="text-4xl font-black opacity-40">AFTER</p>
                    <p class="text-sm opacity-70 mt-2">New design</p>
                </div>
            </div>
        </Item2>
    </Diff>
</Showcase>

@* ── Kbd ───────────────────────────────────────────────────────────────── *@
<Showcase Title="Kbd" Tag="<Kbd>" Description="Keyboard key cap in small, medium, and large sizes.">
    <div class="flex items-center gap-1">
        <Kbd>Ctrl</Kbd>
        <span>+</span>
        <Kbd>Shift</Kbd>
        <span>+</span>
        <Kbd>P</Kbd>
    </div>
    <div class="flex items-center gap-1">
        <Kbd Size="Size.Small">⌘</Kbd>
        <Kbd Size="Size.Small">K</Kbd>
    </div>
    <div class="flex items-center gap-1">
        <Kbd Size="Size.Large">Alt</Kbd>
        <Kbd Size="Size.Large">Tab</Kbd>
    </div>
    <div class="flex items-center gap-2">
        <Kbd>↑</Kbd>
        <Kbd>↓</Kbd>
        <Kbd>←</Kbd>
        <Kbd>→</Kbd>
    </div>
</Showcase>

@* ── List + ListRow ────────────────────────────────────────────────────── *@
<Showcase Title="List + ListRow" Tag="<List> / <ListRow>" Description="Structured list with icon, title, subtitle, and optional trailing content." BodyClass="block space-y-4 max-w-sm">
    <List Shadowed>
        <p class="p-4 text-xs font-semibold uppercase opacity-50 tracking-wide">Recent flights</p>
        <ListRow Icon="flight_takeoff" Title="BX201 — Brussels" Subtitle="Departed 09:00">
            <TrailingContent>
                <span class="badge badge-success badge-sm">On time</span>
            </TrailingContent>
        </ListRow>
        <ListRow Icon="flight_land" Title="LH445 — Frankfurt" Subtitle="Arrived 11:30">
            <TrailingContent>
                <span class="badge badge-info badge-sm">Landed</span>
            </TrailingContent>
        </ListRow>
        <ListRow Icon="warning" Title="SN102 — London" Subtitle="Gate change B4 → B9">
            <TrailingContent>
                <span class="badge badge-warning badge-sm">Delayed</span>
            </TrailingContent>
        </ListRow>
        <ListRow Icon="cancel" Title="TX890 — Madrid" Subtitle="Cancelled 14:00">
            <TrailingContent>
                <span class="badge badge-error badge-sm">Cancelled</span>
            </TrailingContent>
        </ListRow>
    </List>
</Showcase>

@* ── Status ────────────────────────────────────────────────────────────── *@
<Showcase Title="Status" Tag="<Status>" Description="Tiny inline indicator dot with color, size, and optional ping animation.">
    <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2">
            <Status Color="Color.Success" Animated AriaLabel="Online" />
            <span class="text-sm">Online — animated ping</span>
        </div>
        <div class="flex items-center gap-2">
            <Status Color="Color.Warning" Size="StatusSize.Large" AriaLabel="Degraded" />
            <span class="text-sm">Degraded — large</span>
        </div>
        <div class="flex items-center gap-2">
            <Status Color="Color.Error" AriaLabel="Offline" />
            <span class="text-sm">Offline</span>
        </div>
        <div class="flex items-center gap-2">
            <Status Color="Color.Info" Size="StatusSize.Small" AriaLabel="Pending" />
            <span class="text-sm">Pending — small</span>
        </div>
    </div>
    <div class="flex flex-wrap gap-3 items-center ml-6">
        <Status Color="Color.Primary" Size="StatusSize.ExtraSmall" />
        <Status Color="Color.Secondary" Size="StatusSize.Small" />
        <Status Color="Color.Tertiary" />
        <Status Color="Color.Warning" Size="StatusSize.Large" />
        <Status Color="Color.Error" Size="StatusSize.ExtraLarge" />
    </div>
</Showcase>

@* ── Skeleton ──────────────────────────────────────────────────────────── *@
<Showcase Title="Skeleton" Tag="<Skeleton>" Description="Pulsing placeholder blocks in text, rectangle, and circle shapes." BodyClass="block space-y-4 max-w-xs">
    <div class="flex items-center gap-3">
        <Skeleton SkeletonType="SkeletonType.Circle" Width="48px" Height="48px" />
        <div class="flex flex-col gap-2 flex-1">
            <Skeleton Width="60%" Height="1rem" />
            <Skeleton Width="40%" Height="0.75rem" />
        </div>
    </div>
    <Skeleton Width="100%" Height="8rem" SkeletonType="SkeletonType.Rectangle" />
    <div class="flex flex-col gap-2">
        <Skeleton Width="100%" Height="0.875rem" />
        <Skeleton Width="90%" Height="0.875rem" />
        <Skeleton Width="75%" Height="0.875rem" />
    </div>
</Showcase>

@* ── ExpansionPanels ───────────────────────────────────────────────────── *@
<Showcase Title="ExpansionPanels + ExpansionPanel" Tag="<ExpansionPanels> / <ExpansionPanel>" Description="Single-open accordion and multi-open variant using the daisyUI collapse pattern." BodyClass="block space-y-6">
    <div class="max-w-md">
        <p class="text-xs font-semibold uppercase opacity-50 tracking-wide mb-2">Single-open (accordion)</p>
        <ExpansionPanels>
            <ExpansionPanel Text="What is DaisyBlazor?" Icon="help" IsExpanded>
                DaisyBlazor is a Blazor component library built on daisyUI v5 and Tailwind CSS v4.
                It ships zero JavaScript at runtime and uses CSS-only interactions wherever possible.
            </ExpansionPanel>
            <ExpansionPanel Text="How do I install it?" Icon="download">
                Run <code>dotnet add package DaisyBlazor</code> and follow the quick-start guide.
            </ExpansionPanel>
            <ExpansionPanel Text="Is dark mode supported?" Icon="dark_mode">
                Yes. Wrap your app in <code>&lt;ThemeProvider&gt;</code> and toggle the
                <code>data-theme</code> attribute between <em>light</em> and <em>dark</em> (or any
                of the 32 built-in daisyUI themes).
            </ExpansionPanel>
        </ExpansionPanels>
    </div>

    <div class="max-w-md">
        <p class="text-xs font-semibold uppercase opacity-50 tracking-wide mb-2">Multi-open</p>
        <ExpansionPanels MultiExpansion>
            <ExpansionPanel Text="Panel A — open independently" IsExpanded>
                This panel can be expanded without closing other panels.
            </ExpansionPanel>
            <ExpansionPanel Text="Panel B — also open independently">
                Multiple panels may be open at the same time in <code>MultiExpansion</code> mode.
            </ExpansionPanel>
        </ExpansionPanels>
    </div>
</Showcase>

@code
{
    // ── Chip state ────────────────────────────────────────────────────────
    private int _chipClicks = 0;
    private bool _chipVisible = true;

    // ── Carousel slides ───────────────────────────────────────────────────
    private readonly CarouselSlide[] _slides =
    [
        new("Slide 1 — Departures", "#4f46e5"),
        new("Slide 2 — Arrivals",   "#0891b2"),
        new("Slide 3 — Gates",      "#059669"),
        new("Slide 4 — Baggage",    "#d97706")
    ];

    private sealed record CarouselSlide(string Label, string Color);

    // ── Flight table rows ─────────────────────────────────────────────────
    private readonly FlightRow[] _flights =
    [
        new("BX201", "BRU → JFK", "09:00", "On time",  "badge-success"),
        new("LH445", "FRA → BRU", "11:30", "Landed",   "badge-info"),
        new("SN102", "LHR → BRU", "14:15", "Delayed",  "badge-warning"),
        new("TX890", "MAD → BRU", "14:00", "Cancelled","badge-error"),
        new("KL312", "AMS → BRU", "17:45", "Boarding", "badge-primary")
    ];

    private sealed record FlightRow(string Number, string Route, string Departure, string Status, string StatusClass);

    // ── Countdown ─────────────────────────────────────────────────────────
    private int _cdHours   = 2;
    private int _cdMinutes = 34;
    private int _cdSeconds = 17;
    private System.Threading.Timer? _timer;

    private void StartCountdown()
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(async _ =>
        {
            int total = _cdHours * 3600 + _cdMinutes * 60 + _cdSeconds;
            if (total > 0)
            {
                total--;
                int[] digits = Countdown.Digits(total);
                _cdHours   = digits[0];
                _cdMinutes = digits[1];
                _cdSeconds = digits[2];
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                _timer?.Dispose();
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void ResetCountdown()
    {
        _timer?.Dispose();
        _cdHours   = 2;
        _cdMinutes = 34;
        _cdSeconds = 17;
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
