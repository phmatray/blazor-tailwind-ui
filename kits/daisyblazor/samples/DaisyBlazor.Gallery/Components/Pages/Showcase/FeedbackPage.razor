@page "/feedback"
@rendermode InteractiveServer
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Feedback · DaisyBlazor</PageTitle>
<h1 class="text-3xl font-bold font-heading mb-1">Feedback</h1>
<p class="opacity-70 mb-6">Alerts, loading indicators, progress bars, radial progress, tooltips, skeletons, snackbars, and dialogs.</p>

@* ── Alert ── *@
<Showcase Title="Alert" Tag="<Alert>" Description="Severity-coloured banners with optional Soft (Text) or Outline variant." BodyClass="block space-y-3">
    <Alert Severity="Severity.Normal">A plain informational message with no severity colour.</Alert>
    <Alert Severity="Severity.Info">Your boarding pass has been generated successfully.</Alert>
    <Alert Severity="Severity.Success">All flight reports have been submitted.</Alert>
    <Alert Severity="Severity.Warning">Gate change detected — please update passengers.</Alert>
    <Alert Severity="Severity.Error">Connection to the AODB service failed. Retrying…</Alert>

    <div class="divider text-xs opacity-50">Variant.Text (soft)</div>
    <Alert Severity="Severity.Info"    Variant="Variant.Text">Soft info style.</Alert>
    <Alert Severity="Severity.Success" Variant="Variant.Text">Soft success style.</Alert>
    <Alert Severity="Severity.Warning" Variant="Variant.Text">Soft warning style.</Alert>
    <Alert Severity="Severity.Error"   Variant="Variant.Text">Soft error style.</Alert>

    <div class="divider text-xs opacity-50">Variant.Outlined</div>
    <Alert Severity="Severity.Info"    Variant="Variant.Outlined">Outlined info style.</Alert>
    <Alert Severity="Severity.Success" Variant="Variant.Outlined">Outlined success style.</Alert>
    <Alert Severity="Severity.Warning" Variant="Variant.Outlined">Outlined warning style.</Alert>
    <Alert Severity="Severity.Error"   Variant="Variant.Outlined">Outlined error style.</Alert>
</Showcase>

@* ── Loading ── *@
<Showcase Title="Loading" Tag="<Loading>" Description="Six animation types at three sizes." BodyClass="block space-y-6">
    <div class="flex flex-wrap items-center gap-6">
        <Loading Type="LoadingType.Spinner"  Color="Color.Primary"   />
        <Loading Type="LoadingType.Dots"     Color="Color.Secondary" />
        <Loading Type="LoadingType.Ring"     Color="Color.Tertiary"  />
        <Loading Type="LoadingType.Ball"     Color="Color.Info"      />
        <Loading Type="LoadingType.Bars"     Color="Color.Success"   />
        <Loading Type="LoadingType.Infinity" Color="Color.Warning"   />
    </div>
    <div class="flex flex-wrap items-end gap-6">
        <Loading Type="LoadingType.Spinner" Size="Size.Small"  Color="Color.Primary" />
        <Loading Type="LoadingType.Spinner" Size="Size.Medium" Color="Color.Primary" />
        <Loading Type="LoadingType.Spinner" Size="Size.Large"  Color="Color.Primary" />
        <Loading Type="LoadingType.Dots"    SizeOverride="loading-xs" Color="Color.Secondary" />
        <Loading Type="LoadingType.Dots"    SizeOverride="loading-xl" Color="Color.Secondary" />
    </div>
</Showcase>

@* ── ProgressLinear ── *@
<Showcase Title="ProgressLinear" Tag="<ProgressLinear>" Description="Determinate and indeterminate linear bars in every semantic color." BodyClass="block space-y-3">
    <ProgressLinear Value="25"  Color="Color.Primary"   />
    <ProgressLinear Value="50"  Color="Color.Secondary" />
    <ProgressLinear Value="75"  Color="Color.Success"   />
    <ProgressLinear Value="90"  Color="Color.Warning"   />
    <ProgressLinear Value="100" Color="Color.Error"     />
    <ProgressLinear Indeterminate="true" Color="Color.Info" />
    <ProgressLinear Value="60" Color="Color.Primary" Size="Size.Small"  />
    <ProgressLinear Value="60" Color="Color.Primary" Size="Size.Large"  />
</Showcase>

@* ── ProgressCircular ── *@
<Showcase Title="ProgressCircular" Tag="<ProgressCircular>" Description="Circular indeterminate spinner in various colors and sizes." BodyClass="flex flex-wrap items-end gap-6">
    <ProgressCircular Color="Color.Primary"   Size="Size.Small"  />
    <ProgressCircular Color="Color.Secondary" Size="Size.Medium" />
    <ProgressCircular Color="Color.Success"   Size="Size.Large"  />
    <ProgressCircular Color="Color.Warning"   Size="Size.Large"  />
    <ProgressCircular Color="Color.Error"     Size="Size.Large"  />
    <ProgressCircular Color="Color.Info"      Size="Size.Large"  />
</Showcase>

@* ── RadialProgress ── *@
<Showcase Title="RadialProgress" Tag="<RadialProgress>" Description="CSS-driven radial ring, configurable size and thickness." BodyClass="flex flex-wrap items-center gap-6">
    <RadialProgress Value="25"  Color="Color.Primary"   SizeRem="5rem" />
    <RadialProgress Value="50"  Color="Color.Secondary" SizeRem="5rem" />
    <RadialProgress Value="75"  Color="Color.Success"   SizeRem="5rem" />
    <RadialProgress Value="90"  Color="Color.Warning"   SizeRem="5rem" />
    <RadialProgress Value="100" Color="Color.Error"     SizeRem="5rem" />
    <RadialProgress Value="66"  Color="Color.Info"      SizeRem="7rem" Thickness="8px">
        <span class="text-lg font-bold">66%</span>
    </RadialProgress>
</Showcase>

@* ── Tooltip ── *@
<Showcase Title="Tooltip" Tag="<Tooltip>" Description="Hover tooltips in all four placements." BodyClass="flex flex-wrap items-center gap-6 py-8">
    <Tooltip Text="Tooltip on top"    Placement="Placement.Top">
        <button class="btn btn-outline btn-sm">Top</button>
    </Tooltip>
    <Tooltip Text="Tooltip on bottom" Placement="Placement.Bottom">
        <button class="btn btn-outline btn-sm">Bottom</button>
    </Tooltip>
    <Tooltip Text="Tooltip on left"   Placement="Placement.Left">
        <button class="btn btn-outline btn-sm">Left</button>
    </Tooltip>
    <Tooltip Text="Tooltip on right"  Placement="Placement.Right">
        <button class="btn btn-outline btn-sm">Right</button>
    </Tooltip>
    <Tooltip Text="Wrap any element"  Placement="Placement.Top">
        <span class="badge badge-primary cursor-help">Hover me</span>
    </Tooltip>
</Showcase>

@* ── Skeleton ── *@
<Showcase Title="Skeleton" Tag="<Skeleton>" Description="Placeholder shapes for loading states." BodyClass="block space-y-3 max-w-sm">
    <div class="flex items-center gap-4">
        <Skeleton SkeletonType="SkeletonType.Circle" Width="3rem" Height="3rem" />
        <div class="flex-1 flex flex-col gap-2">
            <Skeleton SkeletonType="SkeletonType.Text" Width="60%" Height="1rem" />
            <Skeleton SkeletonType="SkeletonType.Text" Width="90%" Height="0.75rem" />
        </div>
    </div>
    <Skeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="8rem" />
    <Skeleton SkeletonType="SkeletonType.Text" Width="100%" Height="1rem" />
    <Skeleton SkeletonType="SkeletonType.Text" Width="80%"  Height="1rem" />
    <Skeleton SkeletonType="SkeletonType.Text" Width="50%"  Height="1rem" />
</Showcase>

@* ── Snackbar ── *@
<Showcase Title="Snackbar" Tag="ISnackbar" Description="Toast notifications in every severity. Inject ISnackbar and call .Add()." BodyClass="flex flex-wrap gap-3">
    <button class="btn btn-sm"           @onclick="() => ShowSnackbar(Severity.Normal)">Default</button>
    <button class="btn btn-sm btn-info"  @onclick="() => ShowSnackbar(Severity.Info)">Info</button>
    <button class="btn btn-sm btn-success" @onclick="() => ShowSnackbar(Severity.Success)">Success</button>
    <button class="btn btn-sm btn-warning" @onclick="() => ShowSnackbar(Severity.Warning)">Warning</button>
    <button class="btn btn-sm btn-error"   @onclick="() => ShowSnackbar(Severity.Error)">Error</button>
    <button class="btn btn-sm btn-outline" @onclick="ShowPersistentSnackbar">With close button</button>
</Showcase>

@* ── Dialog / Message box ── *@
<Showcase Title="Dialog" Tag="IDialogService" Description="ShowMessageBoxAsync opens a built-in confirm dialog and returns true/false/null." BodyClass="flex flex-wrap items-center gap-4">
    <button class="btn btn-primary btn-sm" @onclick="ShowConfirmDialog">Confirm dialog</button>
    <button class="btn btn-outline btn-sm" @onclick="ShowAlertDialog">Alert (OK only)</button>
    <button class="btn btn-warning btn-sm" @onclick="ShowYesNoDialog">Yes / No</button>

    @if (_dialogResult is not null)
    {
        <span class="text-sm opacity-70">
            Last result: <strong>@(_dialogResult.Value ? "Yes / OK" : "No")</strong>
        </span>
    }
    @if (_dialogCanceled)
    {
        <span class="text-sm opacity-70">Last result: <strong>Canceled</strong></span>
    }
</Showcase>

@code
{
    // ── Snackbar helpers ──────────────────────────────────────────────────────
    private static readonly IReadOnlyDictionary<Severity, string> SnackbarMessages =
        new Dictionary<Severity, string>
        {
            [Severity.Normal]  = "This is a default notification.",
            [Severity.Info]    = "Flight BX402 is now boarding at gate B7.",
            [Severity.Success] = "Flight report submitted successfully.",
            [Severity.Warning] = "Low fuel reserves detected for AH315.",
            [Severity.Error]   = "Failed to connect to the AODB service."
        };

    private void ShowSnackbar(Severity severity)
    {
        string message = SnackbarMessages.TryGetValue(severity, out string? msg) ? msg : "Notification.";
        Snackbar.Add(message, severity);
    }

    private void ShowPersistentSnackbar()
    {
        Snackbar.Add(
            "This toast stays until you close it.",
            Severity.Info,
            opts =>
            {
                opts.ShowCloseIcon = true;
                opts.VisibleStateDuration = 30_000;
            });
    }

    // ── Dialog helpers ────────────────────────────────────────────────────────
    private bool? _dialogResult;
    private bool _dialogCanceled;

    private async Task ShowConfirmDialog()
    {
        _dialogResult = null;
        _dialogCanceled = false;
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Confirm action",
            "Are you sure you want to proceed? This action cannot be undone.",
            yesText: "Confirm",
            cancelText: "Cancel");

        if (result is null)
        {
            _dialogCanceled = true;
        }
        else
        {
            _dialogResult = result;
        }
    }

    private async Task ShowAlertDialog()
    {
        _dialogResult = null;
        _dialogCanceled = false;
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Information",
            "The operation completed successfully.",
            yesText: "OK");

        _dialogResult = result;
    }

    private async Task ShowYesNoDialog()
    {
        _dialogResult = null;
        _dialogCanceled = false;
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Delete record",
            "Do you want to delete this flight report?",
            yesText: "Yes, delete",
            noText: "No, keep it");

        if (result is null)
        {
            _dialogCanceled = true;
        }
        else
        {
            _dialogResult = result;
        }
    }
}
