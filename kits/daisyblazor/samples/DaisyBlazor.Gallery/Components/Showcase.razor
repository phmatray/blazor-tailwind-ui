@* Reusable demo section: a titled card wrapping a live component example. *@

<section class="mb-8">
    <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
        <h2 class="text-xl font-semibold font-heading">@Title</h2>
        @if (!string.IsNullOrEmpty(Tag))
        {
            <code class="text-xs opacity-60 font-mono">@Tag</code>
        }
    </div>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="text-sm opacity-70 mb-3">@Description</p>
    }
    <div class="card bg-base-100 border border-base-300">
        <div class="card-body @BodyClass">
            @ChildContent
        </div>
    </div>
</section>

@code {
    /// <summary>Heading shown above the demo card.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;

    /// <summary>Optional short description under the heading.</summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>Optional monospace tag (e.g. the component name or daisyUI class).</summary>
    [Parameter] public string? Tag { get; set; }

    /// <summary>Extra classes for the demo card body (defaults to a wrapping flex row).</summary>
    [Parameter] public string BodyClass { get; set; } = "flex flex-row flex-wrap items-center gap-4";

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
