@namespace CatalystUI.Components
@inherits CatalystComponentBase
@typeparam TValue

@if (IsSelectedOption)
{
    <div class="@CombineClasses(sharedClasses)">
        @ChildContent
    </div>
}
else
{
    <div class="@GetOptionClasses()"
         @onclick="HandleClick"
         @onmouseenter="HandleMouseEnter"
         @onmouseleave="HandleMouseLeave">
        <svg class="relative hidden size-5 self-center stroke-current group-data-selected/option:inline sm:size-4"
             viewBox="0 0 16 16"
             fill="none"
             aria-hidden="true">
            <path d="M4 8.5l3 3L12 4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span class="@CombineClasses(sharedClasses, "col-start-2")">
            @ChildContent
        </span>
    </div>
}