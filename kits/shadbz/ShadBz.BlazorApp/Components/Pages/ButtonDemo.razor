@page "/button-demo"

<PageTitle>Button Component - Radix UI Blazor</PageTitle>

<Container Size="ContainerSize.Size4">
    <Section Size="SectionSize.Size3">
        <Flex Direction="FlexDirection.Column" Gap="6">
            <!-- Header -->
            <Box>
                <Heading Size="HeadingSize.Size8" Mb="2">Button</Heading>
                <Text Size="4" Color="gray">
                    A versatile button component with multiple variants, sizes, and states.
                </Text>
            </Box>

            <!-- Sizes -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Sizes</Heading>
                <Card>
                    <Flex Gap="3" Align="FlexAlign.Center" Wrap="FlexWrap.Wrap">
                        <Button Size="ButtonSize.Small">Size 1</Button>
                        <Button Size="ButtonSize.Medium">Size 2</Button>
                        <Button Size="ButtonSize.Large">Size 3</Button>
                        <Button Size="ButtonSize.ExtraLarge">Size 4</Button>
                    </Flex>
                </Card>
            </Box>

            <!-- Variants -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Variants</Heading>
                <Card>
                    <Grid Columns="3" Gap="3">
                        @foreach (var variant in Enum.GetValues<ButtonVariant>())
                        {
                            <Button Variant="@variant">@variant</Button>
                        }
                    </Grid>
                </Card>
            </Box>

            <!-- Colors -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Colors</Heading>
                <Card>
                    <Flex Direction="FlexDirection.Column" Gap="3">
                        @foreach (var colorGroup in GetColorGroups())
                        {
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Color="gray" Mb="2">@colorGroup.Name</Text>
                                <Flex Gap="2" Wrap="FlexWrap.Wrap">
                                    @foreach (var color in colorGroup.Colors)
                                    {
                                        <Button Size="ButtonSize.Small" Color="@color">@color</Button>
                                    }
                                </Flex>
                            </Box>
                        }
                    </Flex>
                </Card>
            </Box>

            <!-- High Contrast -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">High Contrast</Heading>
                <Card>
                    <Grid Columns="2" Gap="4">
                        <Box>
                            <Text Size="2" Weight="TextWeight.Medium" Mb="2">Normal</Text>
                            <Flex Gap="2" Direction="FlexDirection.Column">
                                @foreach (var variant in new[] { ButtonVariant.Solid, ButtonVariant.Soft, ButtonVariant.Outline })
                                {
                                    <Button Variant="@variant" HighContrast="false">@variant</Button>
                                }
                            </Flex>
                        </Box>
                        <Box>
                            <Text Size="2" Weight="TextWeight.Medium" Mb="2">High Contrast</Text>
                            <Flex Gap="2" Direction="FlexDirection.Column">
                                @foreach (var variant in new[] { ButtonVariant.Solid, ButtonVariant.Soft, ButtonVariant.Outline })
                                {
                                    <Button Variant="@variant" HighContrast="true">@variant HC</Button>
                                }
                            </Flex>
                        </Box>
                    </Grid>
                </Card>
            </Box>

            <!-- Radius -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Radius</Heading>
                <Card>
                    <Flex Gap="3" Align="FlexAlign.Center" Wrap="FlexWrap.Wrap">
                        <Button Radius="none">None</Button>
                        <Button Radius="small">Small</Button>
                        <Button Radius="medium">Medium</Button>
                        <Button Radius="large">Large</Button>
                        <Button Radius="full">Full</Button>
                    </Flex>
                </Card>
            </Box>

            <!-- States -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">States</Heading>
                <Card>
                    <Flex Direction="FlexDirection.Column" Gap="3">
                        <Flex Gap="3" Align="FlexAlign.Center">
                            <Button>Normal</Button>
                            <Button Disabled="true">Disabled</Button>
                            <Button Loading="true">Loading</Button>
                        </Flex>
                        <Separator />
                        <Flex Gap="3" Align="FlexAlign.Center">
                            <Button Variant="ButtonVariant.Soft">Normal</Button>
                            <Button Variant="ButtonVariant.Soft" Disabled="true">Disabled</Button>
                            <Button Variant="ButtonVariant.Soft" Loading="true">Loading</Button>
                        </Flex>
                    </Flex>
                </Card>
            </Box>

            <!-- AsChild Pattern -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">AsChild Pattern</Heading>
                <Card>
                    <Flex Gap="3">
                        <Button AsChild="true">
                            <a href="#" style="text-decoration: none;">Link as Button</a>
                        </Button>
                        <Button Variant="ButtonVariant.Outline" AsChild="true">
                            <a href="#" style="text-decoration: none;">Outline Link</a>
                        </Button>
                    </Flex>
                </Card>
            </Box>

            <!-- With Icons -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">With Icons</Heading>
                <Card>
                    <Flex Gap="3" Align="FlexAlign.Center" Wrap="FlexWrap.Wrap">
                        <Button>
                            <Text As="span" Style="margin-right: 8px;">←</Text>
                            Previous
                        </Button>
                        <Button>
                            Next
                            <Text As="span" Style="margin-left: 8px;">→</Text>
                        </Button>
                        <Button Variant="ButtonVariant.Soft">
                            <Text As="span" Style="margin-right: 8px;">⚙️</Text>
                            Settings
                        </Button>
                        <Button Variant="ButtonVariant.Ghost" Color="red">
                            <Text As="span" Style="margin-right: 8px;">🗑️</Text>
                            Delete
                        </Button>
                    </Flex>
                </Card>
            </Box>

            <!-- Interactive Example -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Interactive Example</Heading>
                <Card>
                    <Flex Direction="FlexDirection.Column" Gap="4">
                        <Grid Columns="3" Gap="3">
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Mb="2">Size</Text>
                                <SelectRoot @bind-Value="_selectedSize">
                                    <SelectTrigger TValue="string">
                                        <Text>@GetSizeName()</Text>
                                    </SelectTrigger>
                                    <SelectContent TValue="string">
                                        @foreach (var size in Enum.GetValues<ButtonSize>())
                                        {
                                            <SelectItem TValue="string" Value="@size.ToString()">@size</SelectItem>
                                        }
                                    </SelectContent>
                                </SelectRoot>
                            </Box>
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Mb="2">Variant</Text>
                                <SelectRoot @bind-Value="_selectedVariant">
                                    <SelectTrigger TValue="string">
                                        <Text>@_selectedVariant</Text>
                                    </SelectTrigger>
                                    <SelectContent TValue="string">
                                        @foreach (var variant in Enum.GetValues<ButtonVariant>())
                                        {
                                            <SelectItem TValue="string" Value="@variant.ToString()">@variant</SelectItem>
                                        }
                                    </SelectContent>
                                </SelectRoot>
                            </Box>
                            <Box>
                                <Text Size="2" Weight="TextWeight.Medium" Mb="2">Color</Text>
                                <SelectRoot @bind-Value="_selectedColor">
                                    <SelectTrigger TValue="string">
                                        <Text>@_selectedColor</Text>
                                    </SelectTrigger>
                                    <SelectContent TValue="string">
                                        <SelectItem TValue="string" Value="default">Default</SelectItem>
                                        @foreach (var color in new[] { "blue", "green", "red", "purple", "orange", "pink" })
                                        {
                                            <SelectItem TValue="string" Value="@color">@color</SelectItem>
                                        }
                                    </SelectContent>
                                </SelectRoot>
                            </Box>
                        </Grid>
                        
                        <Flex Gap="3" Align="FlexAlign.Center">
                            <Checkbox @bind-Checked="_highContrast" />
                            <Text Size="2">High Contrast</Text>
                            <Checkbox @bind-Checked="_disabled" />
                            <Text Size="2">Disabled</Text>
                            <Checkbox @bind-Checked="_loading" />
                            <Text Size="2">Loading</Text>
                        </Flex>
                        
                        <Separator />
                        
                        <Flex Justify="FlexJustify.Center">
                            <Button 
                                Size="@GetButtonSize()"
                                Variant="@GetButtonVariant()"
                                Color="@(_selectedColor == "default" ? null : _selectedColor)"
                                HighContrast="@_highContrast"
                                Disabled="@_disabled"
                                Loading="@_loading"
                                @onclick="HandleClick">
                                @if (_loading)
                                {
                                    <Text>Loading...</Text>
                                }
                                else
                                {
                                    <Text>@_buttonText</Text>
                                }
                            </Button>
                        </Flex>
                        
                        @if (_clickCount > 0)
                        {
                            <Box>
                                <Text Size="2" Align="TextAlign.Center" Color="gray">
                                    Button clicked @_clickCount @(_clickCount == 1 ? "time" : "times")
                                </Text>
                            </Box>
                        }
                    </Flex>
                </Card>
            </Box>

            <!-- Practical Examples -->
            <Box>
                <Heading Size="HeadingSize.Size6" Mb="4">Practical Examples</Heading>
                <Flex Direction="FlexDirection.Column" Gap="3">
                    <!-- Form Actions -->
                    <Card>
                        <Flex Direction="FlexDirection.Column" Gap="3">
                            <Heading Size="HeadingSize.Size4">Form Actions</Heading>
                            <Flex Gap="2" Justify="FlexJustify.End">
                                <Button Variant="ButtonVariant.Ghost">Cancel</Button>
                                <Button Variant="ButtonVariant.Soft">Save as Draft</Button>
                                <Button>Submit</Button>
                            </Flex>
                        </Flex>
                    </Card>
                    
                    <!-- Destructive Actions -->
                    <Card>
                        <Flex Direction="FlexDirection.Column" Gap="3">
                            <Heading Size="HeadingSize.Size4">Destructive Actions</Heading>
                            <Flex Gap="2">
                                <Button Color="red" Variant="ButtonVariant.Soft">
                                    Remove Item
                                </Button>
                                <Button Color="red" HighContrast="true">
                                    Delete Account
                                </Button>
                            </Flex>
                        </Flex>
                    </Card>
                    
                    <!-- Button Groups -->
                    <Card>
                        <Flex Direction="FlexDirection.Column" Gap="3">
                            <Heading Size="HeadingSize.Size4">Button Groups</Heading>
                            <Flex Style="border: 1px solid var(--gray-6); border-radius: var(--radius-3); overflow: hidden; width: fit-content;">
                                <Button Variant="ButtonVariant.Ghost" Style="border-radius: 0; border-right: 1px solid var(--gray-6);">Left</Button>
                                <Button Variant="ButtonVariant.Ghost" Style="border-radius: 0; border-right: 1px solid var(--gray-6);">Center</Button>
                                <Button Variant="ButtonVariant.Ghost" Style="border-radius: 0;">Right</Button>
                            </Flex>
                        </Flex>
                    </Card>
                </Flex>
            </Box>
        </Flex>
    </Section>
</Container>

@code {
    private string _selectedSize = "Medium";
    private string _selectedVariant = "Solid";
    private string _selectedColor = "default";
    private bool _highContrast = false;
    private bool _disabled = false;
    private bool _loading = false;
    private int _clickCount = 0;
    private string _buttonText = "Click Me";
    
    private void HandleClick()
    {
        if (!_disabled && !_loading)
        {
            _clickCount++;
        }
    }
    
    private ButtonSize GetButtonSize() => Enum.Parse<ButtonSize>(_selectedSize);
    private ButtonVariant GetButtonVariant() => Enum.Parse<ButtonVariant>(_selectedVariant);
    private string GetSizeName() => _selectedSize;
    
    private class ColorGroup
    {
        public string Name { get; set; } = "";
        public string[] Colors { get; set; } = Array.Empty<string>();
    }
    
    private ColorGroup[] GetColorGroups() => new[]
    {
        new ColorGroup 
        { 
            Name = "Grays", 
            Colors = new[] { "gray", "mauve", "slate", "sage", "olive", "sand" }
        },
        new ColorGroup 
        { 
            Name = "Reds", 
            Colors = new[] { "tomato", "red", "ruby", "crimson", "pink", "plum" }
        },
        new ColorGroup 
        { 
            Name = "Purples", 
            Colors = new[] { "purple", "violet", "iris", "indigo" }
        },
        new ColorGroup 
        { 
            Name = "Blues", 
            Colors = new[] { "blue", "cyan", "teal", "sky" }
        },
        new ColorGroup 
        { 
            Name = "Greens", 
            Colors = new[] { "jade", "green", "grass", "mint", "lime" }
        },
        new ColorGroup 
        { 
            Name = "Yellows & Oranges", 
            Colors = new[] { "yellow", "amber", "orange", "brown" }
        }
    };
}