@namespace Radixor.Components.Layout
@inherits Radixor.Components.Base.SpacingComponentBase

@if (AsChild)
{
    <CascadingValue Value="@GetSectionAttributes()" Name="SectionAttributes">
        @ChildContent
    </CascadingValue>
}
else
{
    <section @attributes="GetAllAttributes()" class="@CssClass" style="@GetInlineStyles()">
        @ChildContent
    </section>
}